    <Text id="13" huntingZoneId="248" prevId="3" villagerId="3021">
        <Page social="4">Ça se met dans quel sens?&amp;nbsp;</Page>
    </Text>
    <Text id="14" huntingZoneId="248" prevId="13" villagerId="3022">
        <Page social="4">Je peux avoir une meilleure armure?&amp;nbsp; J'ai pas envie de mourir!&amp;nbsp;</Page>
    </Text>
    <Text id="15" huntingZoneId="248" prevId="14" villagerId="3023">
        <Page social="4">C'est moi le plus fort!&amp;nbsp;</Page>
    </Text>
    <Text id="16" huntingZoneId="248" prevId="15" villagerId="3024">
        <Page social="4">A l'aide!&amp;nbsp; Je veux sortir d'ici!&amp;nbsp;</Page>
    </Text>
    <Text id="17" huntingZoneId="248" prevId="16" villagerId="3025">
        <Page social="4">Je veux que ce sadique me fiche la paix.</Page>
    </Text>
    <Text id="18" huntingZoneId="248" prevId="17" villagerId="3026">
        <Page social="4">Mon estomac est tout noué. C'est normal?&amp;nbsp;</Page>
    </Text>
    <Text id="19" huntingZoneId="248" prevId="18" villagerId="3027">
        <Page social="4">Je n'abandonnerai pas. Pas après ce que les argons ont fait chez moi.</Page>
    </Text>
    <Text id="20" huntingZoneId="248" prevId="19" villagerId="3028">
        <Page social="4">Je ne sais pas si j'ai la carrure...</Page>
    </Text>
    <Text id="21" huntingZoneId="248" prevId="20" villagerId="3029">
        <Page social="4">Continuez à les épauler.&lt;BR&gt;&lt;BR&gt;J'en ai vu quelques-uns vous regarder avec attention.</Page>
    </Text>
