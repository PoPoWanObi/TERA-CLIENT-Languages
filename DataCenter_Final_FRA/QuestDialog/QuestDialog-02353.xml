<QuestDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/QuestDialog QuestDialog.xsd" id="14" huntingZoneId="702" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/QuestDialog">
    <Text id="1" huntingZoneId="0" prevId="0" villagerId="0" />
    <Text id="100" huntingZoneId="205" prevId="0" villagerId="2001">
        <Page social="0">Vous avez trouvé les tuwangis cachés et leur avez donné du courage.</Page>
    </Text>
    <Text id="2" huntingZoneId="205" prevId="0" villagerId="2001">
        <Page social="4">Baba tuwangi peur de grosse grenouille. Il se cachait. L'heure de cérémonie. Devoir le trouver!&amp;nbsp;&lt;NEXTPAGEBUTTON&gt;Où pensez-vous qu'il est?&amp;nbsp;&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="3" huntingZoneId="205" prevId="2" villagerId="2001">
        <Page social="4">Tellement de cachettes!&amp;nbsp; Mais petit tuwangi pas courir bien loin.&lt;BR&gt;&lt;BR&gt;Voici tambour. Trouver cachette et taper tambour pour faire sortir tuwangi.&lt;NEXTPAGEBUTTON&gt;Je vais vous aider.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="4" huntingZoneId="205" prevId="2" villagerId="2001">
        <Page social="4">Tuwangi craintif &lt;NEXTPAGEBUTTON&gt;Je peux vous aider.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="5" huntingZoneId="205" prevId="2" villagerId="2001">
        <Page social="4">Tuwangi craintif &lt;NEXTPAGEBUTTON&gt;Je peux vous aider.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="6" huntingZoneId="205" prevId="2" villagerId="2001">
        <Page social="4">Tuwangi craintif &lt;NEXTPAGEBUTTON&gt;Je peux vous aider.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="7" huntingZoneId="205" prevId="2" villagerId="2001">
        <Page social="4">Tuwangi craintif &lt;NEXTPAGEBUTTON&gt;Je peux vous aider.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="8" huntingZoneId="205" prevId="2" villagerId="2005">
        <Page social="4">Pourquoi tout ce feu?&amp;nbsp;</Page>
    </Text>
    <Text id="9" huntingZoneId="205" prevId="8" villagerId="2006">
        <Page social="4">L'heure est-elle à la soupe de dragon?&amp;nbsp;</Page>
    </Text>
    <Text id="10" huntingZoneId="205" prevId="9" villagerId="2007">
        <Page social="4">Plus de tambour?&amp;nbsp;</Page>
    </Text>
    <Text id="11" huntingZoneId="205" prevId="10" villagerId="2008">
        <Page social="4">Difficile de grandir.</Page>
    </Text>
    <Text id="12" huntingZoneId="205" prevId="11" villagerId="2001">
        <Page social="4">Baba tuwangi revenu!&amp;nbsp; Cérémonie pouvoir commencer. Vous faire bon tuwangi.</Page>
    </Text>
</QuestDialog>
