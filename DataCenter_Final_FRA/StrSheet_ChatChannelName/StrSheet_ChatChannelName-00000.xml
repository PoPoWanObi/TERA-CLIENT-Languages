    <ChatCommandList>
        <CommandCategory name="Discussion">
            <Command name="Ordres du canal de discussion privé :&#xA;Le pseudo du canal de discussion doit comporter de 2 à 8 caractères. Le mot de passe doit comporter 4 chiffres." />
            <Command name="/créer [NomDuCanal] [motdepasse] (créer un canal de discussion privé)" />
            <Command name="/chat [NomDuCanal] [motdepasse] (rejoindre un canal de discussion privé existant.)" />
            <Command name="/quitter [Nom/N°DuCanal]" />
            <Command name="/NomCanal(NuméroCanal) (utiliser la barre oblique / le slash et le nom ou le numéro du canal pour discuter.)" />
            <Command name="/mdp [N°DuCanal] [MotDePasseActuel] [NouveauMotDePasse] (modifier le mot de passe.)" />
            <Command name="/exclure [N°duCanal] [Personnage] (exclure un joueur du canal.)" />
        </CommandCategory>
        <CommandCategory name="Groupe">
            <Command name="Ordres du groupe :" />
            <Command name="/inviter [Personnage] (inviter un personnage dans votre groupe.)" />
            <Command name="/laisser (quitter le groupe.)" />
            <Command name="/chef [MembreDuGroupe] (faire de quelqu'un le chef de groupe.)" />
            <Command name="/exclure [MembreDuGroupe] (exclure un personnage de votre groupe.)" />
            <Command name="/rejoindre [partymember]  (Demande pour rejoindre un groupe.)" />
            <Command name="Ordres du raid :" />
            <Command name="/tous les [partymember]  (Invite un groupe à participer à votre raid.)" />
            <Command name="/assistance [raidmember]  (Invite un groupe à participer à votre raid.)" />
            <Command name="/ra  ou /i (Discussion dans le canal de discussion pour raid)" />
        </CommandCategory>
        <CommandCategory name="RdG">
