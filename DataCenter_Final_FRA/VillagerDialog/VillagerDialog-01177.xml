<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1446" huntingZoneId="72" voiceTypeId="148" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Mieux vaut me laisser superviser le District de Veritas, &lt;PCCLASS:lcase&gt;.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Vous. L'Elfe!&amp;nbsp; Il me faut l'autorisation d'entrer au District de Veritas.</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Qui&amp;nbsp;? Peu importe. J'ai encore beaucoup de chemin à faire. Mon autorisation&amp;nbsp;?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Etrange&amp;nbsp;? Qu'entendez-vous par là&amp;nbsp;?</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Vous&amp;nbsp;? Oh non, pas encore!&amp;nbsp;</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Ha!&amp;nbsp; Essayez de suivre un peu!&amp;nbsp;</Page>
    </Text>
</VillagerDialog>
