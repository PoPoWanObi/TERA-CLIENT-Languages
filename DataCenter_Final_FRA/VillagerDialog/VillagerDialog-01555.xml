<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="3006" huntingZoneId="78" voiceTypeId="86" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="261">Quelles bottes avez-vous donc oublié de lécher pour atterrir ici&amp;nbsp;?</Page>
    </Text>
    <Text id="2" endSocial="14">
        <Page social="0" voiceTypeId="262">Vous êtes ici pour parler ou pour vous battre&amp;nbsp;?</Page>
    </Text>
    <Text id="3" endSocial="14">
        <Page social="4" voiceTypeId="263">Vous commencez à devenir célèbre, camarade.&lt;BR&gt;&lt;BR&gt;Continuez à faire couler le sang.</Page>
    </Text>
    <Text id="4" endSocial="14">
        <Page social="4" voiceTypeId="263">Encore debout, hein&amp;nbsp;?&lt;BR&gt;&lt;BR&gt;Bien. C'est que les argons ne peuvent pas en dire autant.</Page>
    </Text>
</VillagerDialog>
