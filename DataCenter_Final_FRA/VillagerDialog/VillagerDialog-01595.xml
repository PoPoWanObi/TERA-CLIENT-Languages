<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1047" huntingZoneId="79" voiceTypeId="117" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="5">Notre priorité est de broyer les crânes des soldats de Thulsa et de protéger Habere.&lt;BR&gt;&lt;BR&gt;Ce n'est pas sorcier, je ne vois pas pourquoi nous avons besoin d'aide extérieure.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Compris!&amp;nbsp;</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Nous partons pour la Fournaise!&amp;nbsp; Soldats, aux armes!&amp;nbsp;</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Taur!&amp;nbsp; Renseignez l'officier logisticien sur les provisions.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Tahereh!&amp;nbsp; Préparez les soldats.</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">Mobilisez les hommes!&amp;nbsp; Nous allons à la Fournaise!&amp;nbsp;</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0">Je passe devant.</Page>
    </Text>
</VillagerDialog>
