<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="8200" huntingZoneId="122" voiceTypeId="67" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="3" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Bonjour!&amp;nbsp; Vous êtes bien rouge. Comment peut-on vous aider, aujourd'hui&amp;nbsp;?</Page>
    </Text>
    <Text id="20" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Bienvenue!&amp;nbsp; A votre service, quel qu'en soit le prix.</Page>
    </Text>
    <Text id="21" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Bonjour!&amp;nbsp; Dois-je recoudre vos blessures et panser vos brûlures&amp;nbsp;?</Page>
    </Text>
    <Text id="22" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Bonjour!&amp;nbsp; Quel est le fardeau qui vous encombre, à part l'or&amp;nbsp;?</Page>
    </Text>
    <Text id="23" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Bonjour!&amp;nbsp; Je suis prêt à vous servir et à soigner vos blessures. Par où commençons-nous&amp;nbsp;?</Page>
    </Text>
    <Text id="1" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">On dirait que votre compte n'est pas équilibré. Votre sang doit continuer à circuler.</Page>
    </Text>
</VillagerDialog>
