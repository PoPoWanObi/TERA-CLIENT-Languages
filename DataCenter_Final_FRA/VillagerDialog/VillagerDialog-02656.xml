<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1015" huntingZoneId="205" voiceTypeId="16" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" huntingZoneId="205" prevId="0" villagerId="1015" endSocial="14">
        <Page social="4">Ils parlent de reprendre le marais, mais je ne sais pas comment ils comptent s'y prendre.&lt;BR&gt;&lt;BR&gt;Quoi&amp;nbsp;? Qui sont "ils"? Ha, bonne question, je n'ai jamais pensé à demander.</Page>
    </Text>
    <Text id="10001" huntingZoneId="205" prevId="0" villagerId="1015" endSocial="14">
        <Page social="4">Enfin, cet agaçant tambour s'est arrêté.</Page>
    </Text>
    <Text id="10002" huntingZoneId="205" prevId="0" villagerId="1015" endSocial="14">
        <Page social="4">Leurs communications sont interrompues!&amp;nbsp; Allons-y!&amp;nbsp;</Page>
    </Text>
    <Text id="10003" huntingZoneId="205" prevId="0" villagerId="1015" endSocial="14">
        <Page social="4">Il est temps de former les nouvelles recrues.</Page>
    </Text>
</VillagerDialog>
