<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1010" huntingZoneId="232" voiceTypeId="60" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" huntingZoneId="232" prevId="0" villagerId="1010" endSocial="14">
        <Page social="4">Y a-t-il quoi que ce soit que je puisse faire pour vous&amp;nbsp;?</Page>
    </Text>
    <Text id="101" huntingZoneId="232" prevId="0" villagerId="1010" endSocial="0">
        <Page social="0">Aller plus vite que la musique ne vous avancera à rien. Veuillez patienter.</Page>
    </Text>
    <Text id="102" huntingZoneId="232" prevId="0" villagerId="1010" endSocial="0">
        <Page social="0">Hum...</Page>
    </Text>
    <Text id="103" huntingZoneId="232" prevId="0" villagerId="1010" endSocial="0">
        <Page social="0">Ouf... Tout ce qui pouvait être fait l'a été, mais il n'y avait pas assez de temps pour créer une potion faisant tout ce que vous demandiez.</Page>
    </Text>
