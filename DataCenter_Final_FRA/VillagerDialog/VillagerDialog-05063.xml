<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5005" huntingZoneId="410" voiceTypeId="137" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Père...&lt;BR&gt;&lt;BR&gt;... Je vous vengerai.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Adjudant, rassemblez les troupes!&amp;nbsp;</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Quelles unités peut-on mobiliser le plus rapidement&amp;nbsp;?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Qui&amp;nbsp;?</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Vous!&amp;nbsp;</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">C'était votre dernier rire, clown.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0">C'est impossible... Ce sont vraiment les cornes de mon père&amp;nbsp;?</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0">Gardes!&amp;nbsp; Tuez-le!&amp;nbsp;</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0">Louée soit la Vierge au bouclier!&amp;nbsp;</Page>
    </Text>
</VillagerDialog>
