<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1019" huntingZoneId="415" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3">Aidez-moi. J'ai tellement mal.</Page>
    </Text>
    <Text id="2" endSocial="3">
        <Page social="3">Dites-moi la vérité, camarade. On va tous mourir ici, pas vrai&amp;nbsp;?</Page>
    </Text>
    <Text id="3" endSocial="3">
        <Page social="3">Dites à Lohra que je l'aime.</Page>
    </Text>
    <Text id="4" endSocial="3">
        <Page social="3">J'essayais de pousser les gens à monter à bord du canot de sauvetage, mais ça glissait, je n'avais pas de prise.</Page>
    </Text>
</VillagerDialog>
