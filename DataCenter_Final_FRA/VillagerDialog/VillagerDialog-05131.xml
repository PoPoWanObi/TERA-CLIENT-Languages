<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1050" huntingZoneId="415" voiceTypeId="23" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3" voiceTypeId="0">Le saignement ne s'arrêtera pas. Il me faut des bandages!&amp;nbsp; Un garrot!&amp;nbsp; Vite!&amp;nbsp;</Page>
    </Text>
    <Text id="2" endSocial="0">
        <Page social="0" voiceTypeId="0">S'il bouge, il va mourir.</Page>
    </Text>
    <Text id="3" endSocial="0">
        <Page social="0" voiceTypeId="0">Je ne sais pas trop si c'est une bonne chose d'atteindre la plage ou pas.</Page>
    </Text>
    <Text id="4" endSocial="0">
        <Page social="0" voiceTypeId="0">Je ne peux pas faire grand-chose pour les noyés.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Je sais que ça fait mal. Essayez de penser à autre chose. Pensez à chez vous.</Page>
    </Text>
</VillagerDialog>
