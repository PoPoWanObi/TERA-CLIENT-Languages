<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1056" huntingZoneId="415" voiceTypeId="10" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3" voiceTypeId="0">Aidez-nous. Faites quelque chose, je ne sais pas quoi, mais aidez-nous.</Page>
    </Text>
    <Text id="2" endSocial="0">
        <Page social="0" voiceTypeId="0">Je ne rentrerai jamais au bercail.</Page>
    </Text>
    <Text id="3" endSocial="0">
        <Page social="0" voiceTypeId="0">Je n'ai pu sauver personne. J'ai vraiment essayé pourtant.</Page>
    </Text>
    <Text id="4" endSocial="0">
        <Page social="0" voiceTypeId="0">On va tous mourir ici, sur une île qui n'apparait même pas sur les cartes!&amp;nbsp;</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">On ne bat plus en retraite!&amp;nbsp; On y va!&amp;nbsp;</Page>
    </Text>
</VillagerDialog>
