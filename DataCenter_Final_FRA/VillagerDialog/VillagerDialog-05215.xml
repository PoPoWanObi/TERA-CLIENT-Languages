<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1017" huntingZoneId="428" voiceTypeId="127" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Il doit s'agir du Laboratoire de Malachai. Il en émane une énergie magique maléfique.&lt;BR&gt;&lt;BR&gt;Restez sur vos gardes.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">La magie de Malachai s'activera aussitôt que vous invoquerez le téléportail.</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Ca pourrait se révéler dangereux. Prudence...</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">La magie s'est activée.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Quoi qu'il se passe, ne paniquez pas!&amp;nbsp;</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Puissant Balder, dieu du soleil!&amp;nbsp;</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Soumets le mal et plie-le à ta volonté!&amp;nbsp;</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0" voiceTypeId="0">Je vais emprisonner ce mal à l'intérieur de moi. Mettez ce temps de répit à profit pour vous occuper du démon!&amp;nbsp;</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0" voiceTypeId="0">Argh... Je vous laisse vous occuper du reste.</Page>
    </Text>
    <Text id="109" endSocial="0">
        <Page social="0" voiceTypeId="0">J'ai emprisonné cette puissance maléfique à l'intérieur de moi...</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Voici le téléportail menant à la Galerie de Sirjuka.</Page>
    </Text>
    <Text id="111" endSocial="0">
        <Page social="0" voiceTypeId="0">Je vais faire parvenir cette pierre magique à Allemantheia.</Page>
    </Text>
    <Text id="112" endSocial="0">
        <Page social="0" voiceTypeId="0">Nous nous reverrons à Allemantheia.</Page>
    </Text>
</VillagerDialog>
