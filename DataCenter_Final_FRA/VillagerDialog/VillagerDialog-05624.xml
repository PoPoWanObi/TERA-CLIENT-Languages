<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="40011000" huntingZoneId="808" voiceTypeId="95" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Vous pensez que je n'ai que des gardes à ma disposition!&amp;nbsp;</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Ressentez cette douleur pénétrante!&amp;nbsp;&lt;/font&gt;</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Goûtez un peu à la puissance de la magie du sang!&amp;nbsp;&lt;/font&gt;</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Mes draineurs de sang vont vous achever!&amp;nbsp;&lt;/font&gt;</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Assez joué.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Quelle surprise!&amp;nbsp; Vous m'impressionnez... mais pas assez pour que je vous laisse la vie sauve.</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0" voiceTypeId="0">Comment osez-vous!&amp;nbsp; Tuez-les!&amp;nbsp; Tuez-les tous!&amp;nbsp;</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Vous n'auriez pas dû venir!&amp;nbsp;&lt;/font&gt;</Page>
    </Text>
    <Text id="109" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Ceci sera votre tombeau!&amp;nbsp;&lt;/font&gt;</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Pour passer, il faut payer... de votre vie!&amp;nbsp;</Page>
    </Text>
</VillagerDialog>
