<MovieScript xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/MovieScript MovieScript.xsd" id="Q_SWC_TES_Explain_Hasmina" xmlns="https://vezel.dev/novadrop/dc/MovieScript">
    <Script string="Mein Name ist Hasmina." duration="2056" startTime="643" />
    <Script string="Das Mysterium sandte mich hierher," duration="2486" startTime="3995" />
    <Script string="doch ich wäre ohnehin gekommen." duration="2620" startTime="6482" />
    <Script string="Sie haben meine Schwester..." duration="1229" startTime="9103" />
    <Script string="Ich kam zu spät." duration="1521" startTime="10333" />
    <Script string="Doch ich erfuhr etwas, etwas Hilfreiches, als ich gerade Rache nehmen wollte." duration="5813" startTime="13300" />
    <Script string="In den Drei Türmen speichern die Argonen die Lebensenergie," duration="2779" startTime="19115" />
    <Script string="die sie armen Seelen wie meiner Schwester entziehen." duration="3086" startTime="21895" />
    <Script string="Diese Energie bringt eine riesige, fliegende Kreatur zu den Argonenlagern." duration="5026" startTime="25061" />
    <Script string="Dank Euch ist dieser Ort nun nutzlos für sie." duration="3005" startTime="31732" />
    <Script string="Ich könnte natürlich bleiben und trotzdem noch ein paar Argonen töten..." duration="5229" startTime="36400" />
    <Script string="Aber davon wird meine Schwester auch nicht wieder lebendig." duration="3818" startTime="41630" />
    <Script string="Erstatten wir Kaia Bericht." duration="1922" startTime="45490" />
    <Script string="Wenigstens gibt es EINE gute Nachricht." duration="2878" startTime="47413" />
