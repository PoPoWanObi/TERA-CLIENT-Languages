<MovieScript xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/MovieScript MovieScript.xsd" id="Q_HSC_DOD_Field_kaiator_4" xmlns="https://vezel.dev/novadrop/dc/MovieScript">
    <Script string="Ich hatte eine Vision. Ich sah den Grund für das Erdbeben..." duration="4250" startTime="250" />
    <Script string="Der Gott der Furcht ... will einen göttlichen Speer." duration="4000" startTime="4500" />
    <Script string="Wacht auf, Vater! Ich brauche Euch!" duration="3500" startTime="8500" />
    <Script string="Wacht auf. Ich bin's. Icaruna." duration="4100" startTime="12000" />
    <Script string="Ihr wart schon als Säugling laut." duration="4130" startTime="16100" />
    <Script string="Habt Ihr es gefühlt? Sikander hat sich erhoben ... als Kelsaik!" duration="3770" startTime="20230" />
    <Script string="Ich brauche Euer Relikt, Vater ... um Kelsaik zu kontrollieren." duration="4831" startTime="24000" />
    <Script string="Wo ist es?" duration="2246" startTime="29000" />
    <Script string="Hatte ich ein Relikt? Ich entsinne mich nicht." duration="4125" startTime="31975" />
    <Script string="Ich helfe Euch zu erinnern, Vater!" duration="4674" startTime="36100" />
    <Script string="Ahhh! Erinnert Ihr Euch jetzt, Vater?" duration="2823" startTime="42177" />
    <Script string="Vater, so sagt mir doch ..." duration="3434" startTime="45000" />
    <Script string="Nun gut ... ich hatte das Relikt." duration="2600" startTime="50000" />
    <Script string="Aber Ihr könnt es nicht haben!" duration="3400" startTime="52600" />
    <Script string="Nun seht mit an, wie es zerschellt!" duration="4603" startTime="56000" />
    <Script string="Was?" duration="800" startTime="66400" />
    <Script string="Jetzt zeigt Ihr plötzlich Rückgrat?" duration="3132" startTime="67200" />
    <Script string="Das wird Euch leid tun, Vater!" duration="3698" startTime="72000" />
    <Script string="Das Relikt ist zerbrochen." duration="1700" startTime="77300" />
    <Script string="Er wartet auf Euch. Geht zu seinem Speer!" duration="8200" startTime="79000" />
</MovieScript>
