    <Text id="13" huntingZoneId="248" prevId="3" villagerId="3021">
        <Page social="4">Welches Ende gehört wo hin?</Page>
    </Text>
    <Text id="14" huntingZoneId="248" prevId="13" villagerId="3022">
        <Page social="4">Kann ich noch mehr Rüstung haben? Ich will nicht sterben!</Page>
    </Text>
    <Text id="15" huntingZoneId="248" prevId="14" villagerId="3023">
        <Page social="4">Niemand ist zäher als ich!</Page>
    </Text>
    <Text id="16" huntingZoneId="248" prevId="15" villagerId="3024">
        <Page social="4">Hilfe! Bitte holt mich hier raus!</Page>
    </Text>
    <Text id="17" huntingZoneId="248" prevId="16" villagerId="3025">
        <Page social="4">Ich habe diesen Sadisten endgültig satt!</Page>
    </Text>
    <Text id="18" huntingZoneId="248" prevId="17" villagerId="3026">
        <Page social="4">Mir dreht sich der Magen um. Ist das normal?</Page>
    </Text>
    <Text id="19" huntingZoneId="248" prevId="18" villagerId="3027">
        <Page social="4">Ich werde nicht aufgeben! Nicht nachdem, was die Argonen mit meinem Zuhause gemacht haben.</Page>
    </Text>
    <Text id="20" huntingZoneId="248" prevId="19" villagerId="3028">
        <Page social="4">Ich weiß nicht, ob ich das schaffe ...</Page>
    </Text>
    <Text id="21" huntingZoneId="248" prevId="20" villagerId="3029">
        <Page social="4">Setzt ihnen nur weiter zu.&lt;BR&gt;&lt;BR&gt;Wie ich sehe, passen ein paar von ihnen auf.</Page>
    </Text>
