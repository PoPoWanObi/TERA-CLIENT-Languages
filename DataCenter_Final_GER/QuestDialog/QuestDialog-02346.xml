    <Text id="100" huntingZoneId="219" prevId="0" villagerId="1009">
        <Page social="0">Ihr habt an Digorys Ballentreterspiel teilgenommen.</Page>
    </Text>
    <Text id="2" huntingZoneId="219" prevId="0" villagerId="1009">
        <Page social="4">Treten kann jeder, aber nicht jeder kann Heuballen treten.&lt;BR&gt;&lt;BR&gt;Wollt Ihr es mal probieren? &lt;NEXTPAGEBUTTON&gt;"Ja."&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="3" huntingZoneId="219" prevId="2" villagerId="1009">
        <Page social="4">Ihr werdet von Mal zu Mal besser! Hier Euer Gewinn. &lt;NEXTPAGEBUTTON&gt;"Danke."&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
</QuestDialog>
