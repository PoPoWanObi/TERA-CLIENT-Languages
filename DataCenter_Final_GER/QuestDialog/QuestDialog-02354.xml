<QuestDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/QuestDialog QuestDialog.xsd" id="15" huntingZoneId="702" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/QuestDialog">
    <Text id="1" huntingZoneId="0" prevId="0" villagerId="0" />
    <Text id="100" huntingZoneId="205" prevId="0" villagerId="2001">
        <Page social="0">Ihr habt Drache am Spieß für die Teichfeier zubereitet.</Page>
    </Text>
    <Text id="2" huntingZoneId="205" prevId="0" villagerId="2001">
        <Page social="4">Tuwangi hungrig. Müssen Drache essen!&lt;BR&gt;&lt;PCNAME&gt;, Ihr töten, Ihr grillen, wir teilen! &lt;NEXTPAGEBUTTON&gt;Da hab ich den kürzeren Spieß gezogen.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="3" huntingZoneId="205" prevId="2" villagerId="2001">
        <Page social="4">Drachenfleisch machen Tuwangi stark und wild. Bestes Essen für Tuwangi. &lt;NEXTPAGEBUTTON&gt;Ähm, Drachen sind ... ach, egal.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="4" huntingZoneId="205" villagerId="2001">
        <Page social="0">Tötet Drache!</Page>
    </Text>
</QuestDialog>
