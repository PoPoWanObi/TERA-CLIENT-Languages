    <Text id="100" huntingZoneId="205" prevId="0" villagerId="2003">
        <Page social="0">Ihr hattet Spaß beim Trommelspiel, einer Teichfeiertradition zur Vertreibung von Fröschen.</Page>
    </Text>
    <Text id="2" huntingZoneId="205" prevId="0" villagerId="2003">
        <Page social="4">Schlagen rote Trommel, roter Frosch fort! Schlagen lila Trommel, lila Frosch fort!&lt;BR&gt;&lt;BR&gt;Vertreiben Frösche.&lt;NEXTPAGEBUTTON&gt;"Okay."&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
    <Text id="3" huntingZoneId="205" prevId="2" villagerId="2003">
        <Page social="4">Gut getrommelt! Geschenk für Euch! &lt;NEXTPAGEBUTTON&gt;Hat Spaß gemacht.&lt;/NEXTPAGEBUTTON&gt;</Page>
    </Text>
</QuestDialog>
