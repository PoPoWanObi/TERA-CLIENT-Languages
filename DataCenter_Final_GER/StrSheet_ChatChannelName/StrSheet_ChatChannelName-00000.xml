    <ChatCommandList>
        <CommandCategory name="Chat">
            <Command name="Anforderungen für den privaten Chatkanal:&#xA;Der Kanalname muss aus 2-8 alphanumerische Zeichen und das Passwort aus 4 Zahlen bestehen." />
            <Command name="/erstellen [Kanalname] [Passwort] (Erstellt einen privaten Chatkanal.)" />
            <Command name="/chat [Kanalname] [Passwort] (Tretet einem existierenden privaten Chatkanal bei.)" />
            <Command name="/verlassen [Kanalname/#]" />
            <Command name="/kanalname (Kanalnummer) (Gebt Schrägstrich und den Namen oder die Nummer des gewünschten Chatkanals ein.)" />
            <Command name="/passwort [K#] [Aktuelles Passwort] [Neues Passwort] (Ändert das Passwort.)" />
            <Command name="/chatkick [K#] [Charakter] (Entfernt einen Spieler aus dem Kanal.)" />
        </CommandCategory>
        <CommandCategory name="Gruppe">
            <Command name="Gruppenbefehle:" />
            <Command name="/einladen [Charakter] (Ladet einen Charakter in Eure Gruppe ein.)" />
            <Command name="/gruppeverlassen (Verlasst die Gruppe.)" />
            <Command name="/anführer [Gruppenmitglied] (Ernennt jemanden zum Gruppenanführer.)" />
            <Command name="/hinauswerfen [Gruppenmitglied]  (Entfernt einen Charakter aus Eurer Gruppe.)" />
            <Command name="/beitreten [Gruppenmitglied]  (Verschickt eine Anfrage, einer Gruppe beizutreten.)" />
            <Command name="Schlachtgruppenbefehle:" />
            <Command name="/alleeinladen [Gruppenmitglied]  (Ladet eine Gruppe in Eure Schlachtgruppe ein.)" />
            <Command name="/assistieren (Schlachtgruppenmitglied] (Gebt einem Schlachtgruppenmitglied die Rechte zum Einladen.)" />
            <Command name="/h oder /schlachtgruppe (Chattet im Schlachtgruppenkanal.)" />
        </CommandCategory>
        <CommandCategory name="LFG">
