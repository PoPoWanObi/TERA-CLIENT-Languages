    <String id="9916001" string="Beschwört den Lord!" />
    <String id="9916002" string="Der Blutzornlord ist eingetroffen." />
    <String id="9916003" string="Kommt, Würmer! Kommt zu mir!" />
    <String id="9916004" string="Oh, keine Sorge! Es gibt hier viel Schmerz zu erleiden." />
    <String id="9916005" string="Testet mich, wenn Ihr es wagt!" />
    <String id="9916006" string="Sagt der Welt auf Wiedersehen!" />
    <String id="9916007" string="Habt Ihr Schwierigkeiten, stehen zu bleiben?" />
    <String id="9916008" string="Muss ich eingreifen?" />
    <String id="9916009" string="Perimos bewegt sich in Richtung des Maschinenraums, um den Aeonalispfeiler zu zerstören!" />
    <String id="9916010" string="Der Lord ist hier!" />
    <String id="9916011" string="Ihr seid fertig." />
    <String id="9916012" string="Der Lord wird Eure Seelen schlucken!" />
    <String id="9916013" string="Der Lord hat einen Verteidigung verstärkenden Effekt von Blutzornkrieger erhalten." />
    <String id="9916014" string="Der Lord hat Kraft erhöhenden Effekt von Blutzornzauberer erhalten." />
    <String id="9916015" string="Der Lord hat fortwährenden Heileffekt von Blutzornmystiker erhalten." />
    <String id="9916016" string="Dieses Schiff wird mit Euch zugrunde gehen!" />
    <String id="9916017" string="Besiegt die Erzdevaner, ehe ihr Lord eintrifft." />
    <String id="9916018" string="Alle Aeonalispfeiler wurden zerstört. Der Himmelskreuzer fällt!" />
