    <String id="9916026" string="&lt;font size='50'&gt;Umarmt die Dunkelheit!&lt;/font&gt;" />
    <String id="9916027" string="&lt;font size='50'&gt;Weicht dem aus!&lt;/font&gt;" />
    <String id="9916028" string="&lt;font size='50'&gt;Etwas nähert sich vom Himmel.&lt;/font&gt;" />
    <String id="9916029" string="&lt;font size='50'&gt;Thrulkalath schreit vor Schmerzen.&lt;/font&gt;" />
    <String id="9916030" string="&lt;font size='50'&gt;Hat den Aeonalispfeiler beschützt!&lt;/font&gt;" />
    <String id="9916031" string="&lt;font size='40'&gt;Ihr könnt nicht entkommen!&lt;/font&gt;" />
