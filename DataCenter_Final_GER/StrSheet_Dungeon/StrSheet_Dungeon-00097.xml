    <String id="9916033" string="Ein Aeonalispfeiler ist zerbrochen! (7/8)" />
    <String id="9916034" string="&lt;font size='50'&gt;Das Feuer wird Euch verzehren!&lt;/font&gt;" />
    <String id="9916035" string="&lt;font size='50'&gt;Was … Meine Flammen!&lt;/font&gt;" />
    <String id="9916036" string="&lt;font size='50'&gt;Der Himmelskreuzer brennt.&lt;/font&gt;" />
    <String id="9916037" string="&lt;font size='50'&gt;Ein seltsamer Effekt geht vom Deck aus.&lt;/font&gt;" />
    <String id="9916038" string="&lt;font size='50'&gt;Das Feuer breitet sich aus.&lt;/font&gt;" />
    <String id="9916039" string="&lt;font size='50'&gt;Ich!&lt;/font&gt;" />
    <String id="9916040" string="&lt;font size='50'&gt;Werde!&lt;/font&gt;" />
    <String id="9916041" string="&lt;font size='50'&gt;Euch auslöschen!&lt;/font&gt;" />
    <String id="9916042" string="&lt;font size='50'&gt;Ich werde Euch wahre Macht zeigen!&lt;/font&gt;" />
    <String id="9916043" string="Dämpfe erfüllen die Luft." />
    <String id="9916044" string="&lt;font size='50'&gt;Abscheulichkeit absorbiert MP!&lt;/font&gt;" />
    <String id="9916045" string="&lt;font size='50'&gt;Abscheulichkeit absorbiert LP!&lt;/font&gt;" />
    <String id="9916046" string="&lt;font size='50'&gt;Ihr verliert LP.&lt;/font&gt;" />
    <String id="9916047" string="&lt;font size='50'&gt;Ihr verliert mehr LP.&lt;/font&gt;" />
    <String id="9916048" string="&lt;font size='40'&gt;Ich überlasse Euch Putrions Barmherzigkeit … ich muss einen Maschinenraum zerstören ...&lt;/font&gt;" />
    <String id="9916049" string="&lt;font size='40'&gt;Ihr … geht keinen Schritt weiter!&lt;/font&gt;" />
    <String id="9916050" string="&lt;font size='40'&gt;Löscht diese Plagegeister aus!&lt;/font&gt;" />
    <String id="9916051" string="&lt;font size='40'&gt;Ihr denkt, ihr könnt gewinnen. Ausgezeichnet.&lt;/font&gt;" />
    <String id="9916052" string="&lt;font size='40'&gt;Putrions Aura beschützt die Demokronen und Erzdevaner.&lt;/font&gt;" />
    <String id="9916053" string="&lt;font size='50'&gt;In 1 Minute wird ein Neulingssegen aktiviert.&lt;/font&gt;" />
    <String id="9916054" string="&lt;font size='50'&gt;Ein Neulingssegen ist jetzt aktiv (1/1).&lt;/font&gt;" />
    <String id="9916055" string="&lt;font size='50'&gt;Der Eingang schließt in 10 Sekunden.&lt;/font&gt;" />
    <String id="9916056" string="&lt;font size='40'&gt;Es scheint, dass ich einen Schritt hinter den anderen bin. Es ist gut zu wissen, dass Darkan besiegt wurde.&lt;/font&gt;" />
    <String id="9916057" string="&lt;font size='40'&gt;Allerdings gab es auch schon einmal bessere Zeiten für die Sturmflotte, denn Darkan stellt nun keine Gefahr mehr dar.&lt;/font&gt;" />
    <String id="9916058" string="&lt;font size='40'&gt;Die Ingenieure sagen, dass wir so nicht fliegen können. Wir müssen zur Reparatur zurück.&lt;/font&gt;" />
    <String id="9916059" string="&lt;font size='40'&gt;Ihr da! Mein Herr befiehlt, dass Ihr leidet.&lt;/font&gt;" />
    <String id="9916060" string="&lt;font size='40'&gt;Ich verpasse Euch einen Denkzettel wie es Lakan tun würde!&lt;/font&gt;" />
    <String id="9916061" string="&lt;font size='40'&gt;Unglaublich erbärmliche Wesen ...&lt;/font&gt;" />
    <String id="9916062" string="&lt;font size='40'&gt;Es ist ... noch nicht Schluss ...&lt;/font&gt;" />
