    <String id="301001" string="Aufstand der Devaner" />
    <String id="301002" string="&quot;Es gibt viel zu tun.&quot;" />
    <String id="301003" string="&quot;Für die Föderation!&quot;" />
    <String id="301004" string="Meldet Euch bei Präfekt Daven in Holzhausen." />
    <String id="301005" string="&quot;Ich werde es finden!&quot;" />
    <String id="301006" string="Sucht Latton östlich der Pegasusplattform von Holzhausen auf." />
    <String id="301007" string="&quot;Bin schon unterwegs.&quot;" />
    <String id="301008" string="Überquert die Brücke und dann durch die Höhle, dann kommt Ihr zum Bollwerklager in den Wäldern der Vergessenheit und meldet Euch bei Zenturio Neacal." />
    <String id="301009" string="&quot;Er ist so gut wie tot.&quot;" />
    <String id="301010" string="Sucht Chama östlich des Bollwerklagers in den Wäldern der Vergessenheit auf." />
    <String id="301011" string="Dieser Wald gehört mir!" />
    <String id="301012" string="Aargh! W-wie ..." />
    <String id="301013" string="Tötet Tuebenius östlich des Blutpfads." />
    <String id="301014" string="&quot;Sofort!&quot;" />
    <String id="301015" string="Erstattet Zenturio Neacal im Bollwerklager in den Wäldern der Vergessenheit Bericht." />
    <String id="301016" string="&quot;Danke.&quot;" />
    <String id="301017" string="Meldet Euch bei Jodoc in Crescentia." />
