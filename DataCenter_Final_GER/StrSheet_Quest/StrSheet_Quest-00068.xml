    <String id="325001" string="Begleitschutz" />
    <String id="325002" string="Ich bin sicher, dass die Stadt und die Hausierer dankbar sein werden." />
    <String id="325003" string="Vorräte heben die Moral mehr als Ihr glaubt." />
    <String id="325004" string="Beginnt Eure Begleitung." />
    <String id="325005" string="Danke! Ohne Euch hätte ich es nie geschafft." />
    <String id="325006" string="Findet den Hausierer an der östlichen Straße und begleitet ihn nach Crescentia." />
    <String id="325007" string="&quot;Sofort.&quot;" />
    <String id="325008" string="Sprecht mit Justarius am Eingang zu Crescentia." />
    <String id="325009" string="&quot;Wird mir eine Ehre sein.&quot;" />
    <String id="325010" string="Erstattet Corann in Crescentia Bericht." />
