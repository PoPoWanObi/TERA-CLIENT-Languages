    <String id="728001" string="Des Pudels Kern" />
    <String id="728002" string="Seht zu, dass Ihr nicht getötet werdet, ja?" />
    <String id="728003" string="&quot;Für die Föderation.&quot;" />
    <String id="728004" string="Kumaskern" />
    <String id="728005" string="Sammelt den Kern vom Benommenen Kumas in der Umgebung der Ebene von Omphalos." />
    <String id="728006" string="Bringt den Kumaskern zu Denilis, der sich in der östlichen Ebene von Omphalos aufhält." />
    <String id="728007" string="&quot;Danke, Denilis.&quot;" />
</StrSheet_Quest>
