    <String id="1099001" string="Die Hüter des Lichts" />
    <String id="1099002" string="Ich hoffe, dass sich der Aufbau lohnt!" />
    <String id="1099003" string="Sprecht mit Lukan in Castanica." />
    <String id="1099004" string="Hallen von Nakatam" />
    <String id="1099005" string="Das hier muss die Stelle sein." />
    <String id="1099006" string="Nehmt einen Pegasusflug zu den Hallen von Nakatam." />
    <String id="1099007" string="Danke für die Vorgeschichte." />
    <String id="1099008" string="Sprecht mit Sharn, dem Hüter des Lichts." />
    <String id="1099009" string="Ich werde Euch nicht enttäuschen." />
    <String id="1099010" string="Hört Euch die Geschichte von Alptinus an." />
    <String id="1099011" string="Wann muss ich los?" />
    <String id="1099012" string="Empfangt Eure Marschbefehle von Sharn." />
    <String id="1099013" string="Grubers Versteck" />
    <String id="1099014" string="Dort sind sie!" />
    <String id="1099015" string="Findet Grubers Bande am Strand der Boas." />
    <String id="1099016" string="Ihr kommt zu spät, Dummkopf!" />
    <String id="1099017" string="Hüter des Lichts! Ergreift sie!" />
    <String id="1099018" string="Besiegt Gruber und seine Bande." />
    <String id="1099019" string="Ich glaube nicht." />
    <String id="1099020" string="Nehmt das Relikt an Euch." />
    <String id="1099021" string="Ich werde Euch an einen sicheren Ort bringen." />
    <String id="1099022" string="Sprecht mit dem entführten Forscher." />
    <String id="1099023" string="Beginnt Eure Begleitung." />
    <String id="1099024" string="Wir sind in Sicherheit! Wir sehen uns in den Hallen von Nakatam." />
    <String id="1099025" string="Begleitet den Forscher aus der Gefahr." />
    <String id="1099026" string="Danke." />
    <String id="1099027" string="Erstattet Bericht." />
    <String id="1099028" string="Ich danke Euch. Ich werde mein Bestes geben." />
    <String id="1099029" string="Nehmt Eure Belohnung von Alptinus an." />
</StrSheet_Quest>
