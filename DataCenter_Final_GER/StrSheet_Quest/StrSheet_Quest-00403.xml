    <String id="1224001" string="Dirkens Ziel: lästige Piraten" />
    <String id="1224002" string="See-hen wir mal, ob sie mich noch einmal herausfordern werden! Versteht Ihr? Ach, egal. Fort mit Euch!" />
    <String id="1224003" string="Diese Art von Nachricht sende ich gern." />
    <String id="1224004" string="Piratenaugen" />
    <String id="1224005" string="Besiegt die Rotpeitschenvollstrecker am Halsabschneiderstrand und sammelt ihre Augen." />
    <String id="1224006" string="Bringt die Augen zu Sidara." />
    <String id="1224007" string="&quot;Ich habe gerne geholfen.&quot;" />
