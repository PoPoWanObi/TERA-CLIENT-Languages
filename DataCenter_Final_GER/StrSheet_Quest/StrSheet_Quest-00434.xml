    <String id="1304001" string="Die Runde machen" />
    <String id="1304002" string="Meldet Euch bei den Kommandanten jeden Lagers und danach bei Adria." />
    <String id="1304003" string="Ihr erforscht ganz alleine die Insel? Beeindruckend!" />
    <String id="1304004" string="&quot;Das schaffe ich.&quot;" />
    <String id="1304005" string="Sucht Zenturio Kishale am Nördlichen Kontrollpunkt auf." />
    <String id="1304006" string="Ghilliedhuklauen" />
    <String id="1304007" string="Tötet Ghilliedhus und sammelt Ghilliedhuklauen." />
    <String id="1304008" string="Meldet Euch bei Dulari in Dularis Lager." />
    <String id="1304009" string="&quot;Verstanden.&quot;" />
