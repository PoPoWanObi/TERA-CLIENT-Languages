    <String id="2505001" string="Der Wächter von Velika" />
    <String id="2505002" string="Ruhm für Valkyons neuen Recken!" />
    <String id="2505003" string="&quot;Wie Ihr wünscht.&quot;" />
    <String id="2505004" string="Es handelt sich um einen Notrückrufbefehl. Meldet Euch bei Baruch in Tulufan." />
    <String id="2505005" string="&quot;Das werde ich tun.&quot;" />
    <String id="2505006" string="Geht zurück nach Velika und sprecht mit Troius an der Pegasusplattform." />
    <String id="2505007" string="Ich gehe zu ihm." />
    <String id="2505008" string="Erstattet Helferin Uriela vor dem Hauptquartier der Valkyon-Föderation in Velika Bericht." />
    <String id="2505009" string="&quot;Habt Dank.&quot;" />
    <String id="2505010" string="Geht zu Kommandant Seir im Hauptquartier der Valkyon-Föderation in Velika." />
    <String id="2505011" string="&quot;Geht voran.&quot;" />
    <String id="2505012" string="Geht zu Elion, der vor der Göttinnenstatue nahe Veliks Treppe in Velika wartet." />
    <String id="2505013" string="&quot;Es war mir eine Ehre.&quot;" />
    <String id="2505014" string="Sprecht mit Elion." />
</StrSheet_Quest>
