<StrSheet_Quest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/StrSheet_Quest StrSheet_Quest.xsd" xmlns="https://vezel.dev/novadrop/dc/StrSheet_Quest">
    <String id="2801001" string="Visionen des Schicksals" />
    <String id="2801002" string="Sieg für Valkyon." />
    <String id="2801003" string="Das ist wirklich geheimnisvoll." />
    <String id="2801004" string="&quot;Bin schon unterwegs.&quot;" />
    <String id="2801005" string="Sucht Magistrat Jelren in Tralion auf." />
    <String id="2801006" string="&quot;Äh ... alles klar.&quot;" />
    <String id="2801007" string="Trefft Lilone am Kreuzungslager im Heiligen Becken." />
    <String id="2801008" string="&quot;Wie ist das möglich?&quot;" />
    <String id="2801009" string="&quot;Das ist unglaublich.&quot;" />
    <String id="2801010" string="&quot;Ich muss mit Ansine sprechen.&quot;" />
    <String id="2801011" string="Untersucht die Ehrengrabmale in der richtigen Reihenfolge." />
    <String id="2801012" string="&quot;Wünscht mir Glück.&quot;" />
    <String id="2801013" string="Sprecht mit Ansine im Sitz der Suchenden." />
    <String id="2801014" string="&quot;Also gut, dann mal los.&quot;" />
    <String id="2801015" string="Findet die Schicksalsarmilla südlich des Sitzes der Suchenden." />
    <String id="2801016" string="&quot;Das ist beinahe wie Schreiben.&quot;" />
    <String id="2801017" string="Benutzt die Schicksalsarmilla, um die Prüfung zu beginnen." />
    <String id="2801018" string="Verwendet den Fabulastein, um die Prüfung der Seherin zu beginnen." />
    <String id="2801019" string="&quot;Ich danke Euch, große Göttin.&quot;" />
    <String id="2801020" string="Sprecht mit Mystel." />
    <String id="2801021" string="&quot;Bin unterwegs.&quot;" />
    <String id="2801022" string="Kehrt zu Ansine zurück." />
    <String id="2801023" string="&quot;Es ist mir eine Ehre.&quot;" />
    <String id="2801024" string="Erstattet Jelren Bericht." />
</StrSheet_Quest>
