    <String id="3201001" string="Zenobias Verlust" />
    <String id="3201002" string="Sprecht mit Georrif in Acarum. [*Nehmt den Pegasus nach Acarum.*]" />
    <String id="3201003" string="Das ist furchtbar." />
    <String id="3201004" string="&quot;Ich werde tun, was ich kann.&quot;" />
    <String id="3201005" string="Nehmt einen Pegasus, um Georrif in Acarum aufzusuchen." />
    <String id="3201006" string="&quot;Bin schon unterwegs.&quot;" />
    <String id="3201007" string="Sucht Kennance in der Forschungsstation in der Gletscherbucht auf der Sturmebene auf." />
    <String id="3201008" string="&quot;Das krieg ich hin.&quot;" />
    <String id="3201009" string="Findet Versa." />
    <String id="3201010" string="Jagt den Ossugonischen Eisgebieter und bergt die Manawellenkarte." />
    <String id="3201011" string="&quot;Ich kümmere mich darum.&quot;" />
    <String id="3201012" string="Bringt die Manawellenkarte zu Versa." />
    <String id="3201013" string="" />
    <String id="3201014" string="Nehmt die Manawellenkarte an Euch." />
    <String id="3201015" string="Findet das erste Messgerät." />
    <String id="3201016" string="&quot;Und weg sind wir.&quot;" />
    <String id="3201017" string="Findet das zweite Messgerät." />
    <String id="3201018" string="&quot;Bis später.&quot;" />
    <String id="3201019" string="Folgt dem Weg und findet die Person, die die Nachricht geschrieben hat." />
    <String id="3201020" string="&quot;Das mache ich sofort.&quot;" />
    <String id="3201021" string="Sprecht mit Matil." />
    <String id="3201022" string="" />
    <String id="3201023" string="Spektralblut" />
    <String id="3201024" string="Jagt ertrunkene Bootsmänner und ertrunkene Offiziere auf der Sturmebene." />
    <String id="3201025" string="Bringt das Spekralblut zu Matil." />
    <String id="3201026" string="&quot;Ich werde mein Bestes tun.&quot;" />
    <String id="3201027" string="Tötet den dunklen Rufer Seraeno und fangt den Onyxatem ein." />
    <String id="3201028" string="Blutiger Grabstein" />
    <String id="3201029" string="Wendet den Stillen Reiniger auf den Onyxatem an, um mit dem Ergebnis die Grabsteine im Mahlstrom zu zerstören." />
    <String id="3201030" string="&quot;Findet Frieden.&quot;" />
    <String id="3201031" string="Findet den Grabstein im Zentrum des Mahlstroms." />
    <String id="3201032" string="&quot;Was meint Ihr?&quot;" />
    <String id="3201033" string="Sprecht mit Ona." />
    <String id="3201034" string="&quot;Es ist mir eine Ehre. Ich danke Euch.&quot;" />
    <String id="3201035" string="Sprecht mit Zenobia." />
    <String id="3201036" string="&quot;Auf der Stelle!&quot;" />
    <String id="3201037" string="Erstattet Matil Bericht." />
    <String id="3201038" string="&quot;Ich habe gern geholfen.&quot;" />
    <String id="3201039" string="Meldet Euch bei Harule in Acarum." />
</StrSheet_Quest>
