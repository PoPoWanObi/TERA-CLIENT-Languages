    <String id="3438001" string="Barabok brechen" />
    <String id="3438002" string="Unterm Strich: Er muss sterben." />
    <String id="3438003" string="Stellt Euch vor, die Riesen kämen zurück. Ich tue das lieber nicht." />
    <String id="3438004" string="Wie töricht von Euch! Eure Bemühungen werden umsonst sein!" />
    <String id="3438005" string="Der Kaiser wird Euch alle zerschmettern!" />
    <String id="3438006" string="Tötet Barabok und setzt den hochfliegenden Plänen der Riesen ein Ende." />
    <String id="3438007" string="&quot;Wird mir eine Ehre sein.&quot;" />
    <String id="3438008" string="Meldet Euch bei Lucael zurück." />
</StrSheet_Quest>
