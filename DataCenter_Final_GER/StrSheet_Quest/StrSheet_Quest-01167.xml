    <String id="3728001" string="Die Schergen peitschen" />
    <String id="3728002" string="Ich hasse Arachnen. Das tue ich wirklich." />
    <String id="3728003" string="Ihr habt sie in die Flucht geschlagen." />
    <String id="3728004" string="Dämonenpeitsche" />
    <String id="3728005" string="Beseitigt die Naroderarachnen und ihre Schergen, die das Korpusforschungslager umzingelt haben, und sammelt ihre Peitschen." />
    <String id="3728006" string="Erstattet Lufiyah im Korpusforschungslager Bericht." />
    <String id="3728007" string="&quot;Ich habe etwas für Peitschen übrig.&quot;" />
</StrSheet_Quest>
