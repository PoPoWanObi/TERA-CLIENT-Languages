    <String id="3734001" string="Zhaathi muss fallen" />
    <String id="3734002" string="Ich bin sicher, dass er hinter dem ganzen Angriff steckt." />
    <String id="3734003" string="Sind sie schon weg?" />
    <String id="3734004" string="Ein wertloser Oberflächenwandler ... nicht mal Teile davon sind nützlich." />
    <String id="3734005" string="Ihr könnt das ... Unvermeidliche ... höchstens herauszögern ..." />
    <String id="3734006" string="Beseitigt Zhaathi in der Einfallzone." />
    <String id="3734007" string="&quot;Ja, ist jeden Augenblick soweit.&quot;" />
    <String id="3734008" string="Meldet Euch bei Rudh im Unterirdischen Kontrolllager." />
