    <String id="3831001" string="Seltsamer und seltsamer" />
    <String id="3831002" string="Es ist wahrscheinlich unnötig, aber ich mache mir Sorgen um ihn." />
    <String id="3831003" string="Teile! Schicke Teile!" />
    <String id="3831004" string="&quot;Wenn er da ist, finde ich ihn.&quot;" />
    <String id="3831005" string="Sucht nordöstlich des Feuerfelds nach Poihon dem Ingenieur." />
    <String id="3831006" string="Teile von Dredkreak" />
    <String id="3831007" string="Angriff ... Angriff ... Angriff ..." />
    <String id="3831008" string="Besiegt Dredkreak in der Nähe des Feuerfelds und sammelt Teile von ihm auf." />
    <String id="3831009" string="Kehrt zu Poihon zurück." />
    <String id="3831010" string="&quot;Ich bin froh, dass sie Euch gefallen.&quot;" />
