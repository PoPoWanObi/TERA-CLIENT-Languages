    <String id="4236001" string="Ein Geschäftsangebot" />
    <String id="4236002" string="Was haben die Naga und Gula jetzt vor?" />
    <String id="4236003" string="Ah. Die alte Geschichte. Sklaverei." />
    <String id="4236004" string="Nagavertrag" />
    <String id="4236005" string="Greift die Nagamasakari auf der dritten Ebene im Tempel von Dagon an. Sammelt alle Beweise, die Ihr finden könnt." />
    <String id="4236006" string="Meldet Eure Ergebnisse Darim auf der dritten Ebene." />
    <String id="4236007" string="Sprecht mit Bartosia." />
    <String id="4236008" string="&quot;Wird erledigt.&quot;" />
    <String id="4236009" string="Bittet Bartosia, die Dokumente zu entschlüsseln." />
</StrSheet_Quest>
