    <String id="4237001" string="Geflüster der Wiedergeburt" />
    <String id="4237002" string="Mal sehen, ob die Verzauberinnen uns irgendwelche Aufschlüsse liefern können." />
    <String id="4237003" string="Die Wiederbelebung von Dagon? Das ist doch lächerlich!" />
    <String id="4237004" string="Geweihte Tafel" />
    <String id="4237005" string="Beseitigt Nickarverzauberinnen auf der dritten Ebene und bergt Relikte." />
    <String id="4237006" string="Bringt die Tafeln zu Vries auf der dritten Ebene." />
    <String id="4237007" string="Sprecht mit Darim." />
    <String id="4237008" string="&quot;Wir können es aufhalten.&quot;" />
    <String id="4237009" string="Sagt Darim, was Ihr wisst." />
</StrSheet_Quest>
