    <String id="5429001" string="Das Zwielichttal verlassen" />
    <String id="5429002" string="Sie haben ihre heilige Pflicht vernachlässigt." />
    <String id="5429003" string="Wenn sie nicht im Zwielichttal sind, wo sind sie dann?" />
    <String id="5429004" string="Bande der Pflichtbewussten" />
    <String id="5429005" string="Is...ren..." />
    <String id="5429006" string="Wir ... kehren zurück ... zu Euch ..." />
    <String id="5429007" string="Sammelt die Bänder, die an Zentaurenwächter und Schelmische Powries von ihrer Göttin ausgegeben werden." />
    <String id="5429008" string="Bringt die Bänder zu Elma am Wachposten des Großen Tors." />
    <String id="5429009" string="&quot;Das verheißt nichts Gutes.&quot;" />
