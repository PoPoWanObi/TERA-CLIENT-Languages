    <String id="5437001" string="Die Ode an Isren" />
    <String id="5437002" string="Die Akolythen werden Euch den Rest beibringen." />
    <String id="5437003" string="Erinnert Ihr Euch? Ihr erinnert Euch doch, oder?" />
    <String id="5437004" string="&quot;Das kann ich mir merken.&quot;" />
    <String id="5437005" string="&quot;Verstanden.&quot;" />
    <String id="5437006" string="Sprecht mit den Akolythen in der Laube, die den Schlüssel zum Zwielichttal haben." />
    <String id="5437007" string="&quot;Dann mal los!&quot;" />
    <String id="5437008" string="Kehrt mit dem Schlüssel zu Anther im Lager der Fruchtbarkeit zurück." />
</StrSheet_Quest>
