<StrSheet_Quest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/StrSheet_Quest StrSheet_Quest.xsd" xmlns="https://vezel.dev/novadrop/dc/StrSheet_Quest">
    <String id="5501001" string="Der geworfene Handschuh" />
    <String id="5501002" string="Schnell! Lasst Kanmurs Tod nicht umsonst gewesen sein!" />
    <String id="5501003" string="&quot;Er wird nicht entkommen!&quot;" />
    <String id="5501004" string="[Hauptquartier von Allemantheia]: Erstattet Kommandantin Fraya Bericht und erzählt ihr von den Entwicklungen bei Thulsa." />
    <String id="5501005" string="&quot;Es wäre mir eine Ehre.&quot;" />
    <String id="5501006" string="[Kaiatorplatz]: Sucht Kommandant Tamur auf und bittet um Kaiators Hilfe im Kampf gegen Thulsa." />
    <String id="5501007" string="Schmiedeherz" />
    <String id="5501008" string="Ihr habt den Triumphplatz erreicht!" />
    <String id="5501009" string="[Triumphplatz]: Folgt Kommandant Tamur." />
    <String id="5501010" string="&quot;Ich kümmere mich darum.&quot;" />
    <String id="5501011" string="[Triumphplatz]: Die Lage hat sich schlagartig geändert. Geht zu Adjutant Daakem und fragt nach, was Ihr jetzt tun sollt." />
    <String id="5501012" string="&quot;Das werden wir!&quot;" />
    <String id="5501013" string="[Triumphplatz]: Überbringt Ragnar Tamurs Neuigkeiten." />
    <String id="5501014" string="&quot;Nichts zu danken.&quot;" />
    <String id="5501015" string="[Handelshaus]: Überbringt Garuk Tamurs Neuigkeiten." />
    <String id="5501016" string="Danke." />
    <String id="5501017" string="[Einkaufsviertel]: Sagt Karima, dass Ihr bereit seid, mit Tamur zu sprechen." />
    <String id="5501018" string="&quot;Dann los.&quot;" />
    <String id="5501019" string="[Sprecht mit Karima, um das Hauptquartier von Kaiator aufzusuchen.]: Erstattet Tamur Bericht." />
    <String id="5501020" string="Die Göttin Kaia ist hier!" />
    <String id="5501021" string="Sprecht mit Tamur." />
    <String id="5501022" string="&quot;Ich werde Euch nicht enttäuschen!&quot;" />
    <String id="5501023" string="Sprecht mit Kaia." />
</StrSheet_Quest>
