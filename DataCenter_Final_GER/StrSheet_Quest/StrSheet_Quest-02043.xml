    <String id="18115001" string="Augenblick der Wahrheit" />
    <String id="18115002" string="&quot;Es geht um Paesen. Natürlich werde ich helfen.&quot;" />
    <String id="18115003" string="&quot;Macht Ihr Euch tatsächlich Sorgen um ihn?&quot;" />
    <String id="18115004" string="&quot;Ich habe ihn schon seit Längerem nicht mehr gesehen.&quot;" />
    <String id="18115005" string="Findet Solyn und sprecht mit ihr." />
    <String id="18115006" string="&quot;Er ist fähiger, als Ihr denkt. Aber ich werde helfen.&quot;" />
    <String id="18115007" string="&quot;Anscheinend hat er diesen Weg genommen.&quot;" />
    <String id="18115008" string="Haltet nach Paesens Spur Ausschau." />
    <String id="18115009" string="&quot;Er ist vor irgendetwas weggerannt ...&quot;" />
    <String id="18115010" string="Haltet nach Paesens Spur Ausschau." />
    <String id="18115011" string="Rettet Paesen vor den Monstern." />
    <String id="18115012" string="&quot;Das ist wirklich das letzte Mal? Dann ja.&quot;" />
    <String id="18115013" string="Sprecht mit Paesen." />
    <String id="18115014" string="&quot;Ich schätze, Ihr habt ihm den Tag gerettet, Solyn.&quot;" />
    <String id="18115015" string="Bringt den Blumenstrauß zu Solyn." />
    <String id="18115016" string="&quot;Sie scheint weniger abgeneigt zu sein. Das habt Ihr gut gemacht, Paesen.&quot;" />
    <String id="18115017" string="Sprecht mit Paesen." />
    <String id="18115018" string="&quot;Klingt gut. Passt auf Euch auf, Paesen!&quot;" />
    <String id="18115019" string="Sprecht mit Solyn." />
</StrSheet_Quest>
