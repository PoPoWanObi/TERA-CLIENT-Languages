    <String id="18117001" string="Tragödie und Triumph" />
    <String id="18117002" string="&quot;Ich ... in Ordnung. Aber bleibt zurück, bis es sicher ist.&quot;" />
    <String id="18117003" string="Sprecht mit Paesen." />
    <String id="18117004" string="Tötet die Lanzer der Erzdevaner, die das Innere von Energia Celo bewachen." />
    <String id="18117005" string="&quot;Ich werde reingehen - ich habe Gefangene gehört. Bleibt hier.&quot;" />
    <String id="18117006" string="Sprecht mit Paesen." />
    <String id="18117007" string="Tötet die Bulligen Sulcata, welche die Versuchskäfige bewachen." />
    <String id="18117008" string="&quot;Ich verstehe. Sobald ich fertig bin, werde ich mich Euch anschließen.&quot;" />
    <String id="18117009" string="Sprecht mit Solyn." />
    <String id="18117010" string="Zerstört den Käfig, damit die Parthianer entkommen können." />
    <String id="18117011" string="Korridor des Hauptlabors" />
    <String id="18117012" string="Betretet den Korridor des Hauptlabors." />
    <String id="18117013" string="Betretet mit Solyn den Korridor des Hauptlabors." />
    <String id="18117014" string="&quot;Von hier aus können wir nichts unternehmen. Es tut mir leid.&quot;" />
    <String id="18117015" string="Sprecht mit Paesen." />
    <String id="18117016" string="Ich werde dich retten, Solyn ..." />
    <String id="18117017" string="Beschützt Paesen zusammen mit Rhodos." />
    <String id="18117018" string="&quot;Es wird mir ein Vergnügen sein.&quot;" />
    <String id="18117019" string="Sprecht mit Halran." />
    <String id="18117020" string="Benutzt den Hebel, um die Maschine der Sturmbarriere zu überladen." />
    <String id="18117021" string="&quot;Kommt schon, Paesen ... Zeit zu gehen.&quot;" />
    <String id="18117022" string="Sprecht mit Halran." />
