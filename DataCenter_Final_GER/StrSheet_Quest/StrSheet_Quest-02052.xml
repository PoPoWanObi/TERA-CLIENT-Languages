    <String id="18206001" string="Seltsame Wissenschaft" />
    <String id="18206002" string="&quot;Ich habe eine gute Idee.&quot;" />
    <String id="18206003" string="Devanerhorn" />
    <String id="18206004" string="Tötet die Devaner, welche die Höhle bewachen, um an ihre Hörner zu gelangen." />
    <String id="18206005" string="Bringt Keezar Devanerhörner." />
    <String id="18206006" string="&quot;Sind hier denn alle verrückt?&quot;" />
    <String id="18206007" string="&quot;Langsam? Ich bin nicht langsam ...&quot;" />
    <String id="18206008" string="Bittet Keezar darum, den zerbrochenen Anhänger zusammenzusetzen." />
    <String id="18206009" string="&quot;Endlich!&quot;" />
    <String id="18206010" string="Sucht Keezar auf und sprecht mit ihr." />
