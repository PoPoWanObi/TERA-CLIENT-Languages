    <String id="18209001" string="Einen Schritt weiter" />
    <String id="18209002" string="&quot;Ich werde mein Bestes tun.&quot;" />
    <String id="18209003" string="Sprecht mit Madadt und diskutiert den nächsten Schritt." />
    <String id="18209004" string="&quot;Das werde ich. Vielen Dank!&quot;" />
