    <String id="18209007" string="Sprecht mit Karlam." />
    <String id="18209008" string="&quot;Hört sich nach einem Plan an.&quot;" />
    <String id="18209009" string="Sprecht mit dem Hohen Suchenden Janiam." />
    <String id="18209010" string="Tötet Talgrizzlys und Talmugatos beim Kazankamm." />
    <String id="18209011" string="&quot;Danke - und viel Glück hierbei.&quot;" />
    <String id="18209012" string="Fragt den Suchenden Tercad nach dem Hohen Suchenden Janiam." />
