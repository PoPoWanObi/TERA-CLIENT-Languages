    <String id="18211001" string="Unabdingbares Wissen" />
    <String id="18211002" string="Wird gemacht!" />
    <String id="18211003" string="&quot;Hinter wessen Maske verbirgt sich Durion?&quot;" />
    <String id="18211004" string="Lest Oriyns Wille und betretet das Gewölbe von Oriyn." />
    <String id="18211005" string="&quot;Wenn nicht ich, wer sonst?&quot;" />
    <String id="18211006" string="Lest Oriyns Wille, um das Gewölbe zu betreten und Oriyns Arkanum zu lesen." />
    <String id="18211007" string="Oriyns Glyphe" />
    <String id="18211008" string="Betretet das Gewölbe von Oriyn mithilfe von Oriyns Wille und besteht Oriyns Prüfung." />
    <String id="18211009" string="Zeigt Verikam Oriyns Glyphe." />
    <String id="18211010" string="&quot;Nur diese Glyphe ...&quot;" />
    <String id="18211011" string="Ich ... ich denke, dass Ihr damit gemeint seid, Verikam.&quot;" />
    <String id="18211012" string="Bittet Verikam darum, die Glyphe zu übersetzen." />
    <String id="18211013" string="&quot;Ich kann mich nicht um Euch kümmern, wenn Ihr ... so seid ...&quot;" />
    <String id="18211014" string="Fragt Rhodos, was mit Madadt geschehen ist." />
    <String id="18211015" string="&quot;Ich werde mit Dougal sprechen.&quot;" />
    <String id="18211016" string="Sprecht mit Solyn." />
</StrSheet_Quest>
