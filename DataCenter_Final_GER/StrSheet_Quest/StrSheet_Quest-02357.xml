<StrSheet_Quest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/StrSheet_Quest StrSheet_Quest.xsd" xmlns="https://vezel.dev/novadrop/dc/StrSheet_Quest">
    <String id="70212001" string="[Teichfeier] Macht Euch bereit für die Feier" />
    <String id="70212002" string="Das werde ich." />
    <String id="70212003" string="&quot;Ich mag Trommeln.&quot;" />
    <String id="70212004" string="Sprecht mit Haroso, dem Schamanen." />
    <String id="70212005" string="Gutes Versteck" />
    <String id="70212006" string="Ihr habt ein geeignetes Versteck gefunden." />
    <String id="70212007" string="Sucht nach dem Verängstigten Tuwangi." />
    <String id="70212008" string="Spielt Harosos Trommel, damit der Junge Tuwangi sich traut herauszukommen." />
    <String id="70212009" string="Der Junge Tuwangi ist aus seinem Versteck gekommen!" />
    <String id="70212010" string="&quot;Habt keine Angst.&quot;" />
    <String id="70212011" string="Sprecht mit dem Verängstigten Tuwangi." />
    <String id="70212012" string="&quot;Drachen? Wirklich? Drachen?&quot;" />
    <String id="70212013" string="Kehrt zu Haroso zurück." />
    <String id="70212014" string="Jagt Bubudrachen und sammelt ihr Fleisch." />
    <String id="70212015" string="Brennender Froschaltar" />
    <String id="70212016" string="Das ist heiß genug. Spießt das Fleisch auf und grillt es." />
    <String id="70212017" string="Nähert Euch dem Feuer des Brennenden Froschaltars." />
    <String id="70212018" string="&quot;Ich hoffe, Ihr mögt es.&quot;" />
    <String id="70212019" string="Spießt das Fleisch auf und grillt es am Altar." />
    <String id="70212020" string="Bringt den Drachen am Spieß zu Haroso." />
</StrSheet_Quest>
