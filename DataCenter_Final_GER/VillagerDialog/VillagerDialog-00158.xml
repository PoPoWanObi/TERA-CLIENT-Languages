<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1003" huntingZoneId="60" voiceTypeId="69" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" huntingZoneId="60" prevId="0" villagerId="1003" endSocial="14">
        <Page social="4">Was kann ein bescheidener Bankier schon gegen den Andrang der Flüchtlinge tun? Oder gegen den Wahnsinn der Feen?</Page>
    </Text>
    <Text id="2" huntingZoneId="60" prevId="0" villagerId="1003" endSocial="14">
        <Page social="4">Ein toter Kunde ist ein dauerhaft unzufriedener Kunde.</Page>
    </Text>
    <Text id="101" huntingZoneId="60" prevId="0" villagerId="1003" endSocial="14">
        <Page social="4">Wenn man einer Bank nicht trauen kann, wem dann?</Page>
    </Text>
    <Text id="102" huntingZoneId="60" prevId="0" villagerId="1003" endSocial="14">
        <Page social="4">Ihr seht so aus, als ob Euer Gepäck zu schwer wäre. Lasst mich Euch helfen.</Page>
    </Text>
</VillagerDialog>
