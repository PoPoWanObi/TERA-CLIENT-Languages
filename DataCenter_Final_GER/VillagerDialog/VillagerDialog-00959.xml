<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1011" huntingZoneId="71" voiceTypeId="44" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" huntingZoneId="71" prevId="0" villagerId="1011" endSocial="0">
        <Page social="0" voiceTypeId="0">Die Baraka sind an einer Vielzahl Dinge interessiert ... Ich habe noch nie ein Buch wie dieses gesehen.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Oh, das Buch?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Das ist ganz bekannt! Ein verfluchtes Buch.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Angeblich bringt es seinem Besitzer Pech.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Aber ich habe gehört, sie haben trotzdem vor vielen Jahren Tausende davon gedruckt.</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Gerüchten zufolge ist das Buch aus Poporileder gefertigt ...</Page>
    </Text>
</VillagerDialog>
