<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1446" huntingZoneId="72" voiceTypeId="148" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Ihr könnt die Angelegenheiten in Veritas mir überlassen, &lt;PCCLASS&gt;.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Ihr da! Elf! Ich brauche die Erlaubnis, Veritas zu besuchen.</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Wer? Egal. Ich habe noch eine lange Reise vor mir. Meine Erlaubnis?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Seltsam? Was meint Ihr?</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Ihr? Oh, nicht schon wieder!</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Ha! Folgt mir doch, wenn Ihr könnt!</Page>
    </Text>
</VillagerDialog>
