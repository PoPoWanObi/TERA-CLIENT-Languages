<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1023" huntingZoneId="79" voiceTypeId="24" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" huntingZoneId="79" prevId="0" villagerId="1023" endSocial="14">
        <Page social="5">Habere war einst ein Dorf der Hoffnung.&lt;BR&gt;&lt;BR&gt;Jeder Tag bringt jedoch weitere Gründe zum Zweifeln.</Page>
    </Text>
    <Text id="101" endSocial="12">
        <Page social="4">Noch mehr kann ich nicht ertragen.</Page>
    </Text>
    <Text id="102" endSocial="10">
        <Page social="5">Sieht ganz so aus, als würde ich diesen Monat nicht zum Jagen kommen!</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="4">Oh, sucht Ihr nach einem Aman?</Page>
    </Text>
    <Text id="104" endSocial="20">
        <Page social="5">Wir können nicht alles kontrollieren.</Page>
    </Text>
</VillagerDialog>
