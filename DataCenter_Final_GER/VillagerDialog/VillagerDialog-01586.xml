<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1036" huntingZoneId="79" voiceTypeId="112" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="5">Kaias Mission für mich ist das Schmieden von Waffen, mit denen man die Schädel von Thulsas Soldaten einschlagen kann.&lt;BR&gt;&lt;BR&gt;Ihr werdet dafür keine besseren als meine finden.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="4">Was ist los?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">So ist es.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="4">Mir geht es genauso.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="4">Jemand muss hier bleiben und diese Waffen schmieden.</Page>
    </Text>
</VillagerDialog>
