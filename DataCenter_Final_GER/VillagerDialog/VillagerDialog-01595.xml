<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1047" huntingZoneId="79" voiceTypeId="117" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="5">Unser Hauptziel ist es, die Schädel von Thulsas Soldaten einzuschlagen und Habere zu beschützen.&lt;BR&gt;&lt;BR&gt;Das ist nicht so schwer. Ich weiß gar nicht, wieso wir Hilfe von außerhalb anheuern.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Verstanden!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Wir gehen zum Brennofen! Alle Soldaten an die Waffen!</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Taur! Informiert den Versorgungsoffizier von den Vorräten.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Tahereh! Macht die Soldaten gefechtsbereit.</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">Mobilisiert die Männer! Wir gehen zum Brennofen!</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0">Ich geh zuerst rein.</Page>
    </Text>
</VillagerDialog>
