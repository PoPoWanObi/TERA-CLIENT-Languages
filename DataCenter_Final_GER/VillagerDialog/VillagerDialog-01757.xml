<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1008" huntingZoneId="84" voiceTypeId="119" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Die Argonen sind da draußen. Ja, sie sind zerstörerisch und zeigen keine Furcht.&lt;BR&gt;&lt;BR&gt;Ihr habt etwas, das sie nicht haben ... Ehre.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Denkt daran: Argonen zeigen keine Furcht und verhätscheln keine Weichlinge!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Konzentration!</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Macht Ihr Euch auf in den Kampf? Viel Glück!</Page>
    </Text>
</VillagerDialog>
