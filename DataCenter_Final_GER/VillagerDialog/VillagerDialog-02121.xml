<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="220021" huntingZoneId="123" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Ich habe Euch nichts zu geben, Geldraffer!</Page>
    </Text>
    <Text id="2" endSocial="14">
        <Page social="4" voiceTypeId="0">Ich habe keine Zeit für kriecherische Lakaien!</Page>
    </Text>
    <Text id="3" endSocial="14">
        <Page social="4" voiceTypeId="67">Stärke liegt in Zahlen! Auch wenn die Zahl eins ist.</Page>
    </Text>
    <Text id="4" endSocial="14">
        <Page social="4" voiceTypeId="67">Bitte tretet dem Eisernen Orden bei.</Page>
    </Text>
    <Text id="6" endSocial="14">
        <Page social="4" voiceTypeId="67">Ich vertraue Frateks Urteilsvermögen und folge seinen Anweisungen.</Page>
    </Text>
</VillagerDialog>
