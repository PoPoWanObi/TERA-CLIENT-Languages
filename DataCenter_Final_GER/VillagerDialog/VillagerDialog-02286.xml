<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="2012" huntingZoneId="182" voiceTypeId="134" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="0">
        <Page social="5" voiceTypeId="0">Das ist nahe genug, Fremdling! Was wollt Ihr?</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Auf nach Höhenwacht!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Haltet Euren Kopf unten!</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Die Streitkräfte der Parthianer haben die Straße blockiert. Sobald der Khirianwiderstand marschbereit ist, wird diese Belagerungsmaschine die Blockade beseitigen.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Wir müssen reden.</Page>
    </Text>
</VillagerDialog>
