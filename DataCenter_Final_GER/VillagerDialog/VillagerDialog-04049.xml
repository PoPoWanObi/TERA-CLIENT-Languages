    <Text id="1" endSocial="13">
        <Page social="4">Holt mich hier raus!</Page>
    </Text>
    <Text id="10001" endSocial="0">
        <Page social="4">Macht, dass sie aufhören!</Page>
    </Text>
    <Text id="10002" endSocial="0">
        <Page social="4">Rettet uns! Bitte!</Page>
    </Text>
    <Text id="10003" endSocial="0">
        <Page social="4">Sie wollten uns den Spinnen zum Fraß vorwerfen!</Page>
    </Text>
    <Text id="10004" endSocial="0">
        <Page social="4">Ich hatte die Hoffnung schon aufgegeben!</Page>
    </Text>
