<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1103" huntingZoneId="252" voiceTypeId="100" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Seid Ihr {@gender:unser Retter/unsere Retterin}?</Page>
    </Text>
    <Text id="2" endSocial="14">
        <Page social="4">Vielen Dank, dass Ihr mich gerettet habt. Ich war mir sicher, mein Ende wäre gekommen!</Page>
    </Text>
    <Text id="3" endSocial="14">
        <Page social="4">Noch gerade so ... lebendig davongekommen.&lt;BR&gt;&lt;BR&gt;Agh ... Ich frage mich, ob dieser alte Aman in Sicherheit ist ...</Page>
    </Text>
    <Text id="4" endSocial="14">
        <Page social="4">Ich lebe! Ich danke Euch, Kaia!</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Lauft um Euer Leben!</Page>
    </Text>
</VillagerDialog>
