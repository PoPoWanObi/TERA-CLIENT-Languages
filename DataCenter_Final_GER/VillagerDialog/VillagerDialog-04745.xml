    <Text id="1" endSocial="3">
        <Page social="0">(Es scheint sich um einen der Dorfbewohner zu handeln. Sein Gesicht ist schmerzverzerrt. Wenn Ihr nur verstehen könntet, was er sagt ...)</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Folgt mir ... Ich öffne ...</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">... so schwierig ... dass Ihr uns besucht ...</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Andere ... gaben mir ihre Lebenskraft ...</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Hier! Hoch ...</Page>
    </Text>
</VillagerDialog>
