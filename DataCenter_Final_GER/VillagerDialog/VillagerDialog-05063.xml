<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5005" huntingZoneId="410" voiceTypeId="137" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Vater ...&lt;BR&gt;&lt;BR&gt;... ich werde Euch rächen.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Versammelt meine Truppen!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Welche Einheiten können wir am schnellsten aufbieten?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Wer?</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Ihr!</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">Ihr habt zum letzten Mal gelacht, Spaßvogel!</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0">Das kann doch nicht ... Sind das die Hörner meines Vaters?</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0">Wächter! Nehmt ihn auseinander!!</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0">Verbeugt Euch vor der Schildjungfer!</Page>
    </Text>
</VillagerDialog>
