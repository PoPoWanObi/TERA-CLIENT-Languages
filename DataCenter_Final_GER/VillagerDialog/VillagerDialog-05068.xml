<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5010" huntingZoneId="410" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="0">
        <Page social="0">Ha! Ihr solltet Euren Blick sehen!</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Hihihi!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Gefällt Euch mein Geschenk?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Der Meister hat mich die hier behalten lassen. Hihi!</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Bin ich etwa zu einem ungünstigen Zeitpunkt gekommen?</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">Ha! Tötet so viele Ihr wollt. Wo die herkamen, gibt es noch eine Menge!</Page>
    </Text>
</VillagerDialog>
