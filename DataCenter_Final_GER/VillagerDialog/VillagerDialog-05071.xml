<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5001" huntingZoneId="411" voiceTypeId="189" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Hört nicht auf, es zu bearbeiten! Ihr müsst immer wieder dagegen schlagen, um ein gutes Ergebnis zu erzielen.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Gut! Sollen wir loslegen?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Ähm ... Noch nicht. Es reicht noch nicht!</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Leute!</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Und nun die Essenz des Kerns ...</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">Endlich! Ich habe es geschafft!</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0">Ja! Das ist das ideale Behältnis für die Fackel.</Page>
    </Text>
</VillagerDialog>
