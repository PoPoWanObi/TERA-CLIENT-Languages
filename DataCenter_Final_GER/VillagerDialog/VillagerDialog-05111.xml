<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1018" huntingZoneId="415" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3">Ich werde nie wieder Strandurlaub machen. Wenn ich überlebe.</Page>
    </Text>
    <Text id="2" endSocial="3">
        <Page social="3">Ich kann ihnen einfach nicht in die Augen sehen. Da läuft es mir eiskalt den Rücken runter.</Page>
    </Text>
    <Text id="3" endSocial="3">
        <Page social="3">Lasst mich allein! Wir sind alle dem Tode geweiht!</Page>
    </Text>
    <Text id="4" endSocial="1">
        <Page social="3">Die Ertrunkenen? Ich beneide sie.</Page>
    </Text>
</VillagerDialog>
