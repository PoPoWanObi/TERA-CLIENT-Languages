<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1056" huntingZoneId="415" voiceTypeId="10" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3" voiceTypeId="0">Helft uns. Tut, was immer Ihr könnt, aber helft uns.</Page>
    </Text>
    <Text id="2" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich werde nie zurückgehen.</Page>
    </Text>
    <Text id="3" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich konnte niemanden retten. Ehrlich, ich habe es versucht.</Page>
    </Text>
    <Text id="4" endSocial="0">
        <Page social="0" voiceTypeId="0">Wir werden alle auf dieser Insel hier sterben, die nicht mal auf Karten zu sehen ist!</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Kein Rückzug mehr! Ich habe genug!</Page>
    </Text>
</VillagerDialog>
