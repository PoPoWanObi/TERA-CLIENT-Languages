<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1017" huntingZoneId="428" voiceTypeId="127" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Das hier muss Malachais Labor sein. Es ist von der magischen Energie des Bösen erfüllt. &lt;BR&gt;&lt;BR&gt;Bitte seid vorsichtig.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Malachais Magie wird ihre Wirkung entfalten, sobald Ihr das Teleportal beschwört.</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Das könnte gefährlich werden. Seid vorsichtig.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Die Magie wurde aktiviert.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Was auch immer erscheint, habt keine Angst!</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Geliebter Balder, Gott der Sonne!</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Straft das Böse kraft Eurer Autorität!</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich werde die Macht des Bösen in meinem Inneren einfangen. Macht Euch diese Zeit zunutze, um Euch um den Dämonen zu kümmern!</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0" voiceTypeId="0">Ugh... den Rest überlasse ich Euch.</Page>
    </Text>
    <Text id="109" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich habe die Macht des Bösen in mir eingefangen ...</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">(Dieses Teleportal wird Euch zu den Terrassen von Sirjuka bringen.)</Page>
    </Text>
    <Text id="111" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich werde diesen Magiestein nach Allemantheia transportieren.</Page>
    </Text>
    <Text id="112" endSocial="0">
        <Page social="0" voiceTypeId="0">Wir sehen uns in Allemantheia.</Page>
    </Text>
</VillagerDialog>
