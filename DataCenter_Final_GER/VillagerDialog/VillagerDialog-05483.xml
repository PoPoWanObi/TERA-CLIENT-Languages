<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1001" huntingZoneId="496" voiceTypeId="127" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Malachai hat im Geheimen die Energie des Kerns auf den Terrassen von Sirjuka studiert.&lt;BR&gt;&lt;BR&gt;Sie sind von unheilvoller Energie erfüllt ...</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="4" voiceTypeId="0">Was immer erscheinen mag, schützt den Kernkristall!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="4" voiceTypeId="0">Jermir und ich werden Euch helfen.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="4" voiceTypeId="0">Auf geht's, Jermir!</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="4" voiceTypeId="0">Lebt wohl, &lt;PCNAME&gt;.</Page>
    </Text>
</VillagerDialog>
