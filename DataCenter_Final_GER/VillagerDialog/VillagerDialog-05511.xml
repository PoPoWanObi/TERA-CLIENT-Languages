<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5005" huntingZoneId="528" voiceTypeId="137" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Kaiator wird sich keiner Bedrohung unterwerfen! Kaia, die Göttin des Kriegs, wird uns beschützen!</Page>
    </Text>
    <Text id="101" endSocial="14">
        <Page social="4">Was ist all dieser Tumult?</Page>
    </Text>
    <Text id="102" endSocial="14">
        <Page social="4">Was? Da wurde eine Schlacht ausgetragen! Was ist passiert?</Page>
    </Text>
    <Text id="103" endSocial="14">
        <Page social="4">Habt Ihr etwas herausgefunden?</Page>
    </Text>
    <Text id="104" endSocial="14">
        <Page social="4">Genau darum habe ich &lt;PCNAME&gt; mit der Mission betraut.</Page>
    </Text>
    <Text id="105" endSocial="14">
        <Page social="4">Ich weiß, dass ich darauf zählen kann, dass Ihr es zuende bringt!</Page>
    </Text>
</VillagerDialog>
