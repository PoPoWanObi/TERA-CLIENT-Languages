<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5038" huntingZoneId="528" voiceTypeId="58" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="5" voiceTypeId="58">&lt;PCNAME&gt;, Ihr sollt allen Föderationssoldaten als leuchtendes Beispiel gelten.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Wir haben soeben Nachricht von der Front erhalten!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Willkommen zurück, &lt;PCNAME&gt;.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Ihr kommt gerade recht, {@gender:mein Freund/meine Liebe}. Wir haben etwas zu besprechen.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich gehe gerade die Berichte von der Front durch.</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Wir brauchen mehr Informationen, um Shandra Manaya zu finden.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Ich möchte, dass Ihr mich begleitet.</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Helft ihnen. Ich weiß, dass Ihr dem Krieg ein Ende setzen werdet.</Page>
    </Text>
</VillagerDialog>
