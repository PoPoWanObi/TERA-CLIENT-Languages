<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="40011000" huntingZoneId="808" voiceTypeId="95" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Ihr denkt, mir stehen nur Wachen zur Verfügung?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Spürt den stechenden Schmerz!&lt;/font&gt;</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Kostet die Kraft der Blutmagie!&lt;/font&gt;</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Meine Blutsauger werden Euch fertigmachen!&lt;/font&gt;</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Genug gespielt.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Welch eine Überraschung. Ich bin beeindruckt ... allerdings nicht genug, um Euch am Leben zu lassen.</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0" voiceTypeId="0">Wie könnt Ihr es wagen? Tötet sie! Tötet sie alle!</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Ihr hättet nicht herkommen sollen!&lt;/font&gt;</Page>
    </Text>
    <Text id="109" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Dies wird Euer Grab werden!&lt;/font&gt;</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Ihr müsst lediglich dafür bezahlen, um hier vorbeizukommen ... und zwar mit Eurem Leben!</Page>
    </Text>
</VillagerDialog>
