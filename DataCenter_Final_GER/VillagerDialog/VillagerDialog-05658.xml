<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1102" huntingZoneId="818" voiceTypeId="275" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="4">
        <Page social="4" voiceTypeId="275">Was ist passiert? Wurde diese Elinkriegerin entführt?&lt;BR&gt;&lt;BR&gt;Schon wieder Durion! Dieser Mistkerl! Ich werde ihn bei lebendigem Leib häuten!</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="275">Was? Was ist geschehen?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="275">Sagt Euren schwachen Göttern, dass Ihr Euren Tod durch Rhodos' Hand gefunden habt!</Page>
    </Text>
</VillagerDialog>
