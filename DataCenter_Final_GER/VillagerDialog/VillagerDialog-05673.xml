    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Was?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Solyn! Es ist gefährlich, allein zu gehen! Nehmt mich mit!</Page>
