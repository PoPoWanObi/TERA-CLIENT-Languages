<StrSheet_Dungeon xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/StrSheet_Dungeon StrSheet_Dungeon.xsd" xmlns="https://vezel.dev/novadrop/dc/StrSheet_Dungeon">
    <String id="9813001" string="&lt;font size='50'&gt;Явись, Привратник! Защити меня!&lt;/font&gt;" />
    <String id="9813002" string="&lt;font size='50'&gt;Защити меня, смотритель!&lt;/font&gt;" />
    <String id="9813003" string="&lt;font size='50'&gt;Поглотив смотрителя, Баньякас становится нестабильным!&lt;/font&gt;" />
    <String id="9813004" string="&lt;font size='40'&gt;Вам меня не победить!&lt;/font&gt;" />
    <String id="9813005" string="&lt;font size='50'&gt;На помощь Баньякасу приходят древни.&lt;/font&gt;" />
    <String id="9813006" string="&lt;font size='50'&gt;С уничтожением Доминолита Баньякас успокаивается.&lt;/font&gt;" />
    <String id="9813007" string="&lt;font size='50'&gt;Включить обычный режим (временное сообщение)&lt;/font&gt;" />
    <String id="9813008" string="&lt;font size='50'&gt;Защитите меня, пока я исцеляюсь.&lt;/font&gt;" />
    <String id="9813009" string="&lt;font size='50'&gt;Сдержите темных смотрителей!&lt;/font&gt;" />
    <String id="9813010" string="&lt;font size='50'&gt;Стражник восстановил 25% здоровья.&lt;/font&gt;" />
    <String id="9813011" string="&lt;font size='50'&gt;Стражник восстановил 50% здоровья.&lt;/font&gt;" />
    <String id="9813012" string="&lt;font size='50'&gt;Стражник восстановил 75% здоровья.&lt;/font&gt;" />
    <String id="9813013" string="&lt;font size='50'&gt;Стражник полностью восстановился.&lt;/font&gt;" />
    <String id="9813014" string="&lt;font size='50'&gt;Я пробужден!&lt;/font&gt;" />
    <String id="9813015" string="&lt;font size='50'&gt;Темный смотритель впадает в ярость!&lt;/font&gt;" />
    <String id="9813018" string="&lt;font size='50'&gt;Не связывайтесь с нами!&lt;/font&gt;" />
    <String id="9813019" string="&lt;font size='50'&gt;У меня уже достаточно сил, чтобы уничтожить Осколок принуждения!&lt;/font&gt;" />
    <String id="9813020" string="&lt;font size='50'&gt;Вы защитили Стражника!&lt;/font&gt;" />
    <String id="9813021" string="&lt;font size='50'&gt;Я ранен и не могу двигаться. Вы должны защитить меня.&lt;/font&gt;" />
    <String id="9813022" string="&lt;font size='50'&gt;Баньякас получает серьезное ранение и прекращает двигаться.&lt;/font&gt;" />
    <String id="9813023" string="&lt;font size='50'&gt;Осколок принуждения разбивается на куски, и появляется Безумный спороход.&lt;/font&gt;" />
    <String id="9813024" string="&lt;font size='50'&gt;Вы защитили Привратника!&lt;/font&gt;" />
    <String id="9813025" string="&lt;font size='50'&gt;Со мной все в порядке. Помогите петралискам.&lt;/font&gt;" />
    <String id="9813026" string="&lt;font size='50'&gt;Спасибо, что помогли мне. А теперь помогите Баньякасу.&lt;/font&gt;" />
    <String id="9813029" string="Последний из смотрителей Баньякаса вот-вот будет порабощен. Мы должны что-то сделать." />
    <String id="9813030" string="Сможете защитить Стражника, пока он исцеляется? Он прямо за мной. Скорее!" />
    <String id="9813031" string="&lt;font size='50'&gt;С уничтожением гипнотического камня Темные смотрители обрушиваются на землю.&lt;/font&gt;" />
    <String id="9813032" string="&lt;font size='50'&gt;Вход скоро закроется.&lt;/font&gt;" />
    <String id="9813033" string="&lt;font size='50'&gt;Привратник порабощен!&lt;/font&gt;" />
    <String id="9813034" string="&lt;font size='50'&gt;Стражник порабощен!&lt;/font&gt;" />
    <String id="9813035" string="&lt;font size='30'&gt;Достаточно!&lt;/font&gt;" />
    <String id="9813036" string="&lt;font size='30'&gt;Доминолит расколот, и Баньякас вскоре должен прийти в себя.&lt;/font&gt;" />
    <String id="9813037" string="&lt;font size='30'&gt;Спасибо, что защитили наш лес. Хочу передать вам этот небольшой подарок от Баньякаса.&lt;/font&gt;" />
    <String id="9813038" string="&lt;font size='30'&gt;Доминолит расколот, а Баньякас ранен. Вскоре он должен прийти в себя.&lt;/font&gt;" />
    <String id="9813039" string="&lt;font size='30'&gt;Позвольте мне преподнести вам этот небольшой подарок от имени Баньякаса.&lt;/font&gt;" />
    <String id="9813040" string="&lt;font size='30'&gt;Спасибо вам большое!&lt;/font&gt;" />
    <String id="9813041" string="&lt;font size='30'&gt;Даже попав под чары, порабощающие разум, Привратник и Стражник пытались защитить Баньякаса. Нам будет их не хватать.&lt;/font&gt;" />
    <String id="9813042" string="&lt;font size='50'&gt;Приближается волна врагов!&lt;/font&gt;" />
</StrSheet_Dungeon>
