<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1446" huntingZoneId="72" voiceTypeId="148" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">&lt;PCCLASS&gt;! Полагаю, я сама могу разобраться с делами в районе Веритас.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Ты. Эльф! Мне нужно разрешение на посещение Района Веритас.</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Кто? Неважно. Мне еще предстоит долгий путь. Мое разрешение?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Любопытно? Что ты имеешь в виду?</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Ты? Опять? Только не это!</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Ха! Продолжай в том же духе, если сможешь!</Page>
    </Text>
</VillagerDialog>
