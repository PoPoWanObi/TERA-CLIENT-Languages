<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="8100" huntingZoneId="122" voiceTypeId="67" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="3" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Привет, друг! Чем недостойный может служить тебе сегодня?</Page>
    </Text>
    <Text id="20" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Добро пожаловать, друг! Недостойный готов служить тебе.</Page>
    </Text>
    <Text id="21" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Приветствую, друг! Ты нуждаешься в помощи целителя?</Page>
    </Text>
    <Text id="22" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Привет, друг мой! Как недостойный может угодить тебе сегодня?</Page>
    </Text>
    <Text id="23" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Приветствую тебя, мой храбрый друг! Недостойного отправили сюда для выполнения твоих желаний и лечения твоих ран. С чего начнем?</Page>
    </Text>
    <Text id="1" huntingZoneId="121" prevId="0" villagerId="8100" endSocial="14">
        <Page social="4">Очень сожалею! Твоя кровь не для меня, а моя - не для тебя!</Page>
    </Text>
</VillagerDialog>
