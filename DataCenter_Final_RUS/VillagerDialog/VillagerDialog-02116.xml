<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="220020" huntingZoneId="123" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Исчезни! Лучше навсегда.</Page>
    </Text>
    <Text id="2" endSocial="14">
        <Page social="4" voiceTypeId="0">Тебе здесь не место!</Page>
    </Text>
    <Text id="3" endSocial="14">
        <Page social="4" voiceTypeId="130">Чем быстрее я получу то, что мне нужно, тем быстрее ты получишь то, что хочешь.</Page>
    </Text>
    <Text id="4" endSocial="14">
        <Page social="4" voiceTypeId="130">Вступай в ряды Железного Ордена, и ты не пожалеешь.</Page>
    </Text>
    <Text id="6" endSocial="14">
        <Page social="4" voiceTypeId="130">Когда Федерация поймет, что скрывать информацию от меня бесполезно?</Page>
    </Text>
</VillagerDialog>
