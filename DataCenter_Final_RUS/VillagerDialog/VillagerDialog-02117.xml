<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="220021" huntingZoneId="123" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Мне нечего предложить такому алчному до денег типу, как ты!</Page>
    </Text>
    <Text id="2" endSocial="14">
        <Page social="4" voiceTypeId="0">У меня нет времени на раболепствующих подхалимов!</Page>
    </Text>
    <Text id="3" endSocial="14">
        <Page social="4" voiceTypeId="67">Сила определяется количеством. Но даже один - это сила.</Page>
    </Text>
    <Text id="4" endSocial="14">
        <Page social="4" voiceTypeId="67">Вступай в ряды Железного Ордена!</Page>
    </Text>
    <Text id="6" endSocial="14">
        <Page social="4" voiceTypeId="67">Я доверяю мнению Фратеко и во всем ему повинуюсь.</Page>
    </Text>
</VillagerDialog>
