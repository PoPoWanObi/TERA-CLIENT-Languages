<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1027" huntingZoneId="256" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="0">(Это, должно быть, один из горожан. Его лицо исказила гримаса ужаса. Если бы можно было разобрать, что он говорит...)</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Иди за мной... Я открою...</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">...Как же тяжело... Тебе нас видеть...</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Другие... Дай мне их жизненную силу...</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Сюда! Наверх...</Page>
    </Text>
</VillagerDialog>
