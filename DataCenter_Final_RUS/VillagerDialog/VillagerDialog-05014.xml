<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5005" huntingZoneId="410" voiceTypeId="137" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Отец...&lt;BR&gt;&lt;BR&gt;Я отомщу за тебя...</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0">Адъютант, собрать войска!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0">Какие отряды мы сможем перебросить быстрее всего?</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0">Кто?</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0">Эй, ты!</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0">Это был твой последний смешок!</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0">Не может быть... Это рога моего отца?</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0">Стража! Разорвать его на части!</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0">Все поклоняются Воительнице!</Page>
    </Text>
</VillagerDialog>
