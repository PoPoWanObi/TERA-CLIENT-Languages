    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Бойцы!</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">А теперь, эссенция Ядра...</Page>
    </Text>
    <Text id="105" endSocial="0">
