<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1019" huntingZoneId="415" voiceTypeId="0" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3">Помогите! Ужасная боль.</Page>
    </Text>
    <Text id="2" endSocial="3">
        <Page social="3">Дай это мне, друг. Мы все умрем здесь, не так ли?</Page>
    </Text>
    <Text id="3" endSocial="3">
        <Page social="3">Передай Лохре, что я ее люблю.</Page>
    </Text>
    <Text id="4" endSocial="3">
        <Page social="3">Я пытался втащить людей в шлюпку, но они были такими скользкими, а моя хватка ослабела.</Page>
    </Text>
</VillagerDialog>
