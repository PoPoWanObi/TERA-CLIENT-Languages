<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1050" huntingZoneId="415" voiceTypeId="23" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3" voiceTypeId="0">Кровотечение не останавливается. Еще бинтов! Тряпки! Хоть что-нибудь!</Page>
    </Text>
    <Text id="2" endSocial="0">
        <Page social="0" voiceTypeId="0">Если он пошевелится, он умрет.</Page>
    </Text>
    <Text id="3" endSocial="0">
        <Page social="0" voiceTypeId="0">Я не знаю, можно ли сказать, что выбравшимся на берег повезло...</Page>
    </Text>
    <Text id="4" endSocial="0">
        <Page social="0" voiceTypeId="0">Немногое я могу сделать для утонувших.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Я знаю - больно. Постарайся подумать о чем-нибудь другом. Думай о доме.</Page>
    </Text>
</VillagerDialog>
