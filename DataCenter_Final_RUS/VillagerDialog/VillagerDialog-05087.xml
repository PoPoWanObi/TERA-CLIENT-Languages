<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1056" huntingZoneId="415" voiceTypeId="10" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="3" voiceTypeId="0">Помоги нам! Делай что хочешь, но помоги нам.</Page>
    </Text>
    <Text id="2" endSocial="0">
        <Page social="0" voiceTypeId="0">Я никогда не вернусь.</Page>
    </Text>
    <Text id="3" endSocial="0">
        <Page social="0" voiceTypeId="0">Я не смог никого спасти. Я пытался, но...</Page>
    </Text>
    <Text id="4" endSocial="0">
        <Page social="0" voiceTypeId="0">Мы все умрем здесь - на острове, которого даже нет на картах.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Больше никаких отступлений! Клянусь!</Page>
    </Text>
</VillagerDialog>
