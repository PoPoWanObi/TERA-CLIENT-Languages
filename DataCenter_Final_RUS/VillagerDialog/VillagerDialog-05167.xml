<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="1017" huntingZoneId="428" voiceTypeId="127" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Это, должно быть, лаборатория Малахая. Она полна черной магической энергии. &lt;BR&gt;&lt;BR&gt;Пожалуйста, будь осторожнее.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Магия Малахая начинает действовать в тот момент, когда ты войдешь в телепорт.</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Тебя может подстерегать опасность. Пожалуйста, будь осторожнее.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Магия активирована.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Что бы ни появилось, не бойся!</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Дорогой Балдер, бог Солнца.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Покарай демона своей властью!</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0" voiceTypeId="0">Я заберу силу демона. Воспользуйся этим моментом, чтобы уничтожить его!</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0" voiceTypeId="0">Угу... Остальное сделаешь ты.</Page>
    </Text>
    <Text id="109" endSocial="0">
        <Page social="0" voiceTypeId="0">Я заберу силу демона.</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Телепорт ведет в Галерею Сирджуки.</Page>
    </Text>
    <Text id="111" endSocial="0">
        <Page social="0" voiceTypeId="0">Я доставлю этот магический камень в Аллемантею.</Page>
    </Text>
    <Text id="112" endSocial="0">
        <Page social="0" voiceTypeId="0">Увидимся в Аллемантее.</Page>
    </Text>
</VillagerDialog>
