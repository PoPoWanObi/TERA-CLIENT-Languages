    <Text id="1" endSocial="14">
        <Page social="4" voiceTypeId="0">Малахай тайно изучал энергию Ядра в Галерее Сирджуки.&lt;BR&gt;&lt;BR&gt;Оно переполнено темной энергией...</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="4" voiceTypeId="0">Что бы ни произошло, защити кристалл Ядра!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="4" voiceTypeId="0">Джермир и я поможем тебе.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="4" voiceTypeId="0">Джермир, давай!</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="4" voiceTypeId="0">Прощай, &lt;PCNAME&gt;.</Page>
    </Text>
</VillagerDialog>
