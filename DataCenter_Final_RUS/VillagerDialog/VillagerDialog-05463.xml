<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5005" huntingZoneId="528" voiceTypeId="137" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="14">
        <Page social="4">Кайатор не испугается любых угроз! Кайа, богиня войны, защитит нас!</Page>
    </Text>
    <Text id="101" endSocial="14">
        <Page social="4">Почему такое волнение?</Page>
    </Text>
    <Text id="102" endSocial="14">
        <Page social="4">Что? Там была битва! Что случилось?</Page>
    </Text>
    <Text id="103" endSocial="14">
        <Page social="4">Есть ли новости?</Page>
    </Text>
    <Text id="104" endSocial="14">
        <Page social="4">Именно поэтому &lt;PCNAME&gt; и будет выполнять это задание.</Page>
    </Text>
    <Text id="105" endSocial="14">
        <Page social="4">Я знаю, что могу положиться на вас в этом задании!</Page>
    </Text>
</VillagerDialog>
