<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="5038" huntingZoneId="528" voiceTypeId="58" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="1" endSocial="3">
        <Page social="5" voiceTypeId="58">&lt;PCNAME&gt;, ты станешь примером для подражания всем солдатам Федерации.</Page>
    </Text>
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Мы только что получили новости с фронта!</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Снова добро пожаловать, &lt;PCNAME&gt;.</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">Временно, мой друг, временно. Мы должны поговорить.</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">Я просто просматриваю сводки с фронта.</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Нам нужно больше информации о местонахождении Шандры Манайи.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Ступай за мной. Мне нужна охрана.</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Помоги им. Я знаю, ты хочешь закончить войну.</Page>
    </Text>
</VillagerDialog>
