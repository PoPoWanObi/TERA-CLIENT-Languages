<VillagerDialog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://vezel.dev/novadrop/dc/VillagerDialog VillagerDialog.xsd" id="40011000" huntingZoneId="808" voiceTypeId="95" xmlns="https://vezel.dev/novadrop/dc/VillagerDialog">
    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Ты же не думаешь, что это место охраняется только лишь отрядами стражи?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Ощути боль!&lt;/font&gt;</Page>
    </Text>
    <Text id="103" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Познай силу магии крови!&lt;/font&gt;</Page>
    </Text>
    <Text id="104" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Мои кроволиты тебя прикончат!&lt;/font&gt;</Page>
    </Text>
    <Text id="105" endSocial="0">
        <Page social="0" voiceTypeId="0">Хватит игр.</Page>
    </Text>
    <Text id="106" endSocial="0">
        <Page social="0" voiceTypeId="0">Вот это сюрприз! Впечатляет. Но не настолько, чтобы позволить тебе жить.</Page>
    </Text>
    <Text id="107" endSocial="0">
        <Page social="0" voiceTypeId="0">Да как ты смеешь! Убить! Всех их убить!</Page>
    </Text>
    <Text id="108" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Тебе не следовало приходить!&lt;/font&gt;</Page>
    </Text>
    <Text id="109" endSocial="0">
        <Page social="0" voiceTypeId="0">&lt;font color='#FF0000'&gt;Это место станет твоей могилой!&lt;/font&gt;</Page>
    </Text>
    <Text id="110" endSocial="0">
        <Page social="0" voiceTypeId="0">Чтобы пройти, придется заплатить... кровью!</Page>
    </Text>
</VillagerDialog>
