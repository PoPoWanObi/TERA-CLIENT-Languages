    <Text id="101" endSocial="0">
        <Page social="0" voiceTypeId="0">Что?</Page>
    </Text>
    <Text id="102" endSocial="0">
        <Page social="0" voiceTypeId="0">Золин! Здесь опасно ходить в одиночку! Возьми меня с собой!</Page>
